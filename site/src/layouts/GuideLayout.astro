---
/**
 * Renders a single collecting guide: answer-first long-form content with Article schema,
 * an optional FAQPage block, breadcrumbs, and a visible "Last updated" freshness date.
 */
import type { CollectionEntry } from 'astro:content';
import { render, getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Prose from '@/components/Prose.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import RelatedGuides from '@/components/guides/RelatedGuides.astro';
import { article, faqPage } from '@/lib/schema';
import { SITE } from '@/lib/site';

interface Props {
  entry: CollectionEntry<'guides'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const url = `/guides/${entry.id}`;
const isCollectorsGuide = data.cluster === 'collectors-guide';

let prevChapter: CollectionEntry<'guides'> | null = null;
let nextChapter: CollectionEntry<'guides'> | null = null;

if (isCollectorsGuide) {
  const siblings = (await getCollection('guides', ({ data: d }) =>
    d.cluster === 'collectors-guide' && !d.draft,
  )).sort(
    (a, b) => (a.data.chapterOrder ?? 0) - (b.data.chapterOrder ?? 0),
  );
  const idx = siblings.findIndex((s) => s.id === entry.id);
  if (idx > 0) prevChapter = siblings[idx - 1]!;
  if (idx >= 0 && idx < siblings.length - 1) nextChapter = siblings[idx + 1]!;
}

const breadcrumbTrail = isCollectorsGuide
  ? [
      { name: 'Home', url: '/' },
      { name: "The Tolkien Collector's Guide", url: '/collectors-guide' },
      { name: data.title, url },
    ]
  : [
      { name: 'Home', url: '/' },
      { name: 'Guides', url: '/guides' },
      { name: data.title, url },
    ];

const dateFormat = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const dateModified = data.dateModified ?? data.datePublished;
const lastUpdated = dateFormat.format(dateModified);

let schemaImage: string | undefined;
if (data.heroImage) {
  const optimized = await getImage({ src: data.heroImage, width: 1200, format: 'jpg' });
  schemaImage = new URL(optimized.src, SITE.url).href;
}

const schema: Record<string, unknown>[] = [
  article({
    title: data.title,
    description: data.description,
    url,
    datePublished: data.datePublished.toISOString(),
    dateModified: dateModified.toISOString(),
    image: schemaImage,
  }),
];
if (data.faq && data.faq.length > 0) {
  schema.push(faqPage(data.faq));
}
---
<BaseLayout
  title={`${data.title} | Collecting Guides`}
  description={data.description}
  type="article"
  publishedTime={data.datePublished.toISOString()}
  modifiedTime={dateModified.toISOString()}
  schema={schema}
>
  <Section tone="parchment" space="md">
    <Breadcrumbs trail={breadcrumbTrail} />
    <Reveal as="header" class="mt-8 max-w-[var(--content-max)]">
      {isCollectorsGuide && (
        <p class="mb-4 font-ui text-sm">
          <a
            href="/collectors-guide"
            class="text-[var(--color-oxblood-600)] underline decoration-[var(--color-gold-600)]/40 underline-offset-4 hover:decoration-[var(--color-oxblood-600)]"
          >
            Part of The Tolkien Collector's Guide
          </a>
        </p>
      )}
      {data.pillar && (
        <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
          Cornerstone Guide
        </p>
      )}
      <h1 class="mt-2 font-display text-4xl leading-tight text-[var(--color-midnight-900)] sm:text-5xl">
        {data.title}
      </h1>
      <p class="mt-5 text-xl text-[var(--color-muted)]">{data.description}</p>
      <p class="mt-6 font-ui text-sm text-[var(--color-muted)]">
        By Mark Faith · Last updated: <time datetime={dateModified.toISOString()}>{lastUpdated}</time>
      </p>
    </Reveal>
  </Section>

  {data.heroImage && (
    <Section space="sm">
      <Reveal as="figure" mode="fade" class="mx-auto max-w-[var(--page-max)]">
        <Image
          src={data.heroImage}
          alt={data.heroAlt ?? data.title}
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 1024px, 100vw"
          class="w-full rounded-sm shadow-sm"
        />
      </Reveal>
    </Section>
  )}

  <Section space="md">
    <Reveal>
      <Prose as="article" class="mx-auto">
        <Content />
      </Prose>
    </Reveal>

    {data.faq && data.faq.length > 0 && (
      <Reveal class="mx-auto mt-16 max-w-[var(--content-max)]">
        <h2 id="faq" class="font-display text-3xl text-[var(--color-midnight-900)]">
          Frequently asked questions
        </h2>
        <dl class="mt-8 divide-y divide-[var(--color-gold-600)]/20">
          {data.faq.map((item) => (
            <div class="py-6">
              <dt class="font-display text-xl text-[var(--color-midnight-900)]">{item.question}</dt>
              <dd class="mt-3 text-[var(--color-text)]">{item.answer}</dd>
            </div>
          ))}
        </dl>
      </Reveal>
    )}

    {isCollectorsGuide && (prevChapter || nextChapter) && (
      <Reveal class="mx-auto mt-16 max-w-[var(--content-max)] border-t border-[var(--color-gold-600)]/20 pt-8">
        <nav aria-label="Chapter navigation" class="grid gap-4 sm:grid-cols-2">
          {prevChapter ? (
            <a
              href={`/guides/${prevChapter.id}`}
              class="group rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 p-5 transition-colors hover:border-[var(--color-gold-500)]"
            >
              <span class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
                Previous chapter
              </span>
              <span class="mt-2 block font-display text-xl text-[var(--color-midnight-900)] group-hover:text-[var(--color-oxblood-600)]">
                {prevChapter.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
          {nextChapter ? (
            <a
              href={`/guides/${nextChapter.id}`}
              class="group rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 p-5 text-left transition-colors hover:border-[var(--color-gold-500)] sm:text-right"
            >
              <span class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
                Next chapter
              </span>
              <span class="mt-2 block font-display text-xl text-[var(--color-midnight-900)] group-hover:text-[var(--color-oxblood-600)]">
                {nextChapter.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
        </nav>
      </Reveal>
    )}

    <RelatedGuides currentId={entry.id} />

    <Reveal class="mx-auto mt-16 max-w-[var(--content-max)] border-t border-[var(--color-gold-600)]/20 pt-8">
      <p class="font-ui text-sm text-[var(--color-muted)]">
        Spending thousands on a Tolkien first edition? Mark Faith has specialised in rare
        Tolkien books for 25+ years. Email
        <a class="text-[var(--color-oxblood-600)] underline" href={`mailto:${SITE.email}`}>
          {SITE.email}
        </a>
        for direct advice, or browse current listings on
        <a
          class="text-[var(--color-oxblood-600)] underline"
          href="https://www.ebay.co.uk/str/festivalartandbooks"
          rel="noopener"
        >eBay</a>
        and
        <a
          class="text-[var(--color-oxblood-600)] underline"
          href="https://www.abebooks.co.uk/festival-art-and-books-aberdyfi/51881760/sf"
          rel="noopener"
        >AbeBooks</a>.
      </p>
    </Reveal>
  </Section>
</BaseLayout>
