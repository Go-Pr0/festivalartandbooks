---
/**
 * Renders a single collecting guide: answer-first long-form content with Article schema,
 * an optional FAQPage block, breadcrumbs, and a visible "Last updated" freshness date.
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { Image } from 'astro:assets';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Prose from '@/components/Prose.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import { article, faqPage } from '@/lib/schema';
import { SITE } from '@/lib/site';

interface Props {
  entry: CollectionEntry<'guides'>;
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const url = `/guides/${entry.id}`;

const dateFormat = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const dateModified = data.dateModified ?? data.datePublished;
const lastUpdated = dateFormat.format(dateModified);

const schema: Record<string, unknown>[] = [
  article({
    title: data.title,
    description: data.description,
    url,
    datePublished: data.datePublished.toISOString(),
    dateModified: dateModified.toISOString(),
  }),
];
if (data.faq && data.faq.length > 0) {
  schema.push(faqPage(data.faq));
}
---
<BaseLayout
  title={`${data.title} | Collecting Guides`}
  description={data.description}
  type="article"
  schema={schema}
>
  <Section tone="parchment" space="md">
    <Breadcrumbs
      trail={[
        { name: 'Home', url: '/' },
        { name: 'Guides', url: '/guides' },
        { name: data.title, url },
      ]}
    />
    <Reveal as="header" class="mt-8 max-w-[var(--content-max)]">
      {data.pillar && (
        <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
          Cornerstone Guide
        </p>
      )}
      <h1 class="mt-2 font-display text-4xl leading-tight text-[var(--color-midnight-900)] sm:text-5xl">
        {data.title}
      </h1>
      <p class="mt-5 text-xl text-[var(--color-muted)]">{data.description}</p>
      <p class="mt-6 font-ui text-sm text-[var(--color-muted)]">
        By Mark Faith · Last updated: <time datetime={dateModified.toISOString()}>{lastUpdated}</time>
      </p>
    </Reveal>
  </Section>

  {data.heroImage && (
    <Section space="sm">
      <Reveal as="figure" mode="fade" class="mx-auto max-w-[var(--page-max)]">
        <Image
          src={data.heroImage}
          alt={data.heroAlt ?? data.title}
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 1024px, 100vw"
          class="w-full rounded-sm shadow-sm"
        />
      </Reveal>
    </Section>
  )}

  <Section space="md">
    <Reveal>
      <Prose as="article" class="mx-auto">
        <Content />
      </Prose>
    </Reveal>

    {data.faq && data.faq.length > 0 && (
      <Reveal class="mx-auto mt-16 max-w-[var(--content-max)]">
        <h2 id="faq" class="font-display text-3xl text-[var(--color-midnight-900)]">
          Frequently asked questions
        </h2>
        <dl class="mt-8 divide-y divide-[var(--color-gold-600)]/20">
          {data.faq.map((item) => (
            <div class="py-6">
              <dt class="font-display text-xl text-[var(--color-midnight-900)]">{item.question}</dt>
              <dd class="mt-3 text-[var(--color-text)]">{item.answer}</dd>
            </div>
          ))}
        </dl>
      </Reveal>
    )}

    <Reveal class="mx-auto mt-16 max-w-[var(--content-max)] border-t border-[var(--color-gold-600)]/20 pt-8">
      <p class="font-ui text-sm text-[var(--color-muted)]">
        Spending thousands on a Tolkien first edition? Mark Faith has specialised in rare
        Tolkien books for 25+ years. Email
        <a class="text-[var(--color-oxblood-600)] underline" href={`mailto:${SITE.email}`}>
          {SITE.email}
        </a>
        for direct advice, or browse current listings on
        <a
          class="text-[var(--color-oxblood-600)] underline"
          href="https://www.ebay.co.uk/str/festivalartandbooks"
          rel="noopener"
        >eBay</a>
        and
        <a
          class="text-[var(--color-oxblood-600)] underline"
          href="https://www.abebooks.co.uk/festival-art-and-books-aberdyfi/51881760/sf"
          rel="noopener"
        >AbeBooks</a>.
      </p>
    </Reveal>
  </Section>
</BaseLayout>
