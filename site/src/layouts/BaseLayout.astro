---
/**
 * Base layout: the page shell + sitewide <head> (SEO, fonts, sitewide schema, view
 * transitions) and the real Header / Footer. Every page renders inside this.
 */
import { ClientRouter } from 'astro:transitions';

// Fonts (self-hosted via Fontsource; font-display: swap is the package default).
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/eb-garamond/400.css';
import '@fontsource/eb-garamond/400-italic.css';
import '@fontsource/eb-garamond/500.css';
import '@fontsource/eb-garamond/600.css';
import '@fontsource-variable/inter';

import '@/styles/global.css';

import Seo from '@/components/Seo.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { organization, person, website } from '@/lib/schema';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  /** Extra page-specific schema blocks (Article, Book, Product, FAQPage, Breadcrumbs…). */
  schema?: Record<string, any> | Record<string, any>[];
  /** Set false on the homepage to suppress sitewide entities if a page emits its own. */
  bodyClass?: string;
}
const { title, description, image, type, noindex, publishedTime, modifiedTime, schema, bodyClass = '' } = Astro.props;

// Sitewide entities on every page; page-specific schema appended.
const sitewide = [organization(), person(), website()];
const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const allSchema = [...sitewide, ...pageSchema];
---
<!doctype html>
<html lang="en-GB" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon-32.png?v=3" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16.png?v=3" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" sizes="180x180" />
    <meta name="theme-color" content="#14224f" />
    <Seo title={title} description={description} image={image} type={type} noindex={noindex} publishedTime={publishedTime} modifiedTime={modifiedTime} />
    <SchemaOrg schema={allSchema} />
    <ClientRouter />
  </head>
  <body class:list={['min-h-screen bg-[var(--color-bg)] text-[var(--color-text)] font-text', bodyClass]}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      import { initReveal } from '@/scripts/reveal';
      import { initCountUp } from '@/scripts/countup';
      import { initVisitCounter } from '@/scripts/visit-counter';

      function boot(): void {
        initReveal();
        initCountUp();
        initVisitCounter();
      }
      boot();
      document.addEventListener('astro:after-swap', boot);
    </script>
  </body>
</html>
