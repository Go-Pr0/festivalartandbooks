---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

const title = 'Page not found';
const description = 'The page you requested could not be found on Festival Art & Books.';
---
<BaseLayout title={title} description={description} noindex>
  <Section tone="midnight" space="lg">
    <Breadcrumbs
      class="!text-[var(--color-parchment)]/70"
      trail={[
        { name: 'Home', url: '/' },
        { name: 'Not found', url: '/404' },
      ]}
    />
    <Reveal as="header" class="mt-8 max-w-[var(--content-max)]">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
        404
      </p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl">
        {title}
      </h1>
      <p class="mt-6 text-xl text-[var(--color-parchment)]/80">
        That URL does not match any page on this site. You may have followed an old link,
        or the item may no longer be listed.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href="/" variant="gold">Back to home</Button>
        <Button href="/books" variant="ghost">Browse the catalogue</Button>
        <Button href="/guides" variant="ghost">Collecting guides</Button>
      </div>
    </Reveal>
  </Section>
</BaseLayout>
