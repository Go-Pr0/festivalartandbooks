---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import StatBand from '@/components/StatBand.astro';
import MarketplaceCTA from '@/components/MarketplaceCTA.astro';
import Button from '@/components/Button.astro';
import Timeline from '@/components/story/Timeline.astro';
import Figure from '@/components/story/Figure.astro';
import type { TimelineEntry } from '@/components/story/TimelineItem.astro';
import type { StatItem } from '@/components/StatBand.astro';
import { article } from '@/lib/schema';
import { getEntry } from 'astro:content';

const page = (await getEntry('pageContent', 'about'))!;
const t = page.data.text as Record<string, string>;
const exploreCards = (page.data.text as Record<string, unknown>).exploreCards as {
  title: string;
  description: string;
  href: string;
}[];

const title = page.data.seo!.title!;
const description = page.data.seo!.description!;

const trail = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about' },
];

const stats: StatItem[] = page.data.stats!;
const journey: TimelineEntry[] = page.data.timeline!;

const fig = (k: string) => page.data.figures!.find((f) => f.key === k)!;
const markPortrait = fig('markPortrait');
const markWilburSmith = fig('markWilburSmith');
const gtcFounders = fig('gtcFounders');
const gtcEarlyTalks = fig('gtcEarlyTalks');

const schema = article({
  title,
  description,
  url: '/about',
  datePublished: '2024-01-01',
  dateModified: '2026-06-25',
  image: '/og/about.jpg', // TODO: Mark to confirm / add a dedicated OG image
});
---
<BaseLayout title={title} description={description} type="article" schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <div class="mt-10 grid items-center gap-12 lg:grid-cols-[1.4fr_1fr]">
      <Reveal as="div" mode="up">
        <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">
          {t.heroEyebrow}
        </p>
        <h1 id="about-mark-faith" class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
          {t.heroH1}
        </h1>
        <p class="mt-6 max-w-prose font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
          {t.heroIntro}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/contact" variant="gold">{t.ctaContact}</Button>
          <Button
            href="/rare-tolkien-books-collectables"
            variant="ghost"
            class="text-[var(--color-parchment)] border-[var(--color-parchment)]/40 hover:bg-[var(--color-parchment)]/10"
          >
            {' '}{t.ctaBrowse}{' '}
          </Button>
        </div>
      </Reveal>
      <Figure
        src={markPortrait.src}
        alt={markPortrait.alt}
        delay={markPortrait.delay}
        frame={markPortrait.frame as 'default' | 'portrait'}
        sizes={markPortrait.sizes}
      />
    </div>
  </Section>

  <Section tone="midnight" space="md" class="border-t border-[var(--color-gold-600)]/20">
    <StatBand stats={stats} tone="light" />
  </Section>

  <Section space="lg">
    <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr] lg:items-start">
      <Reveal as="div" mode="up" class="prose-paper">
        <h2 id="what-makes-a-tolkien-expert" class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.expertHeading}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.expertP1}
        </p>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.expertP2}
        </p>
        <figure class="mt-8 border-l-2 border-[var(--color-gold-500)] pl-5">
          <blockquote class="font-display text-2xl italic leading-snug text-[var(--color-midnight-900)]">
            {t.expertBlockquote}
          </blockquote>
          <figcaption class="mt-3 font-ui text-sm text-[var(--color-muted)]">
            {t.expertFigcaption}
          </figcaption>
        </figure>
      </Reveal>
      <div class="space-y-8">
        <Figure
          src={markWilburSmith.src}
          alt={markWilburSmith.alt}
          caption={markWilburSmith.caption}
          delay={markWilburSmith.delay}
        />
        <Figure
          src={gtcFounders.src}
          alt={gtcFounders.alt}
          caption={gtcFounders.caption}
          delay={gtcFounders.delay}
        />
      </div>
    </div>
  </Section>

  <Section tone="parchment" space="lg">
    <Reveal as="div" mode="up">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">{t.journeyEyebrow}</p>
      <h2 id="the-journey" class="mt-2 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        {t.journeyHeading}
      </h2>
      <p class="mt-3 max-w-prose font-text text-lg text-[var(--color-muted)]">
        {t.journeyIntro}
      </p>
    </Reveal>
    <div class="mt-12">
      <Timeline entries={journey} />
    </div>
  </Section>

  <Section space="lg">
    <div class="grid gap-12 lg:grid-cols-[1fr_1fr] lg:items-center">
      <Reveal as="div" mode="up" class="prose-paper">
        <h2 id="why-this-site-exists" class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.whySiteHeading}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.whySiteP1}
        </p>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.whySiteP2}
        </p>
        <p class="mt-6 font-ui text-sm text-[var(--color-muted)]">
          <Fragment set:html={t.whySiteSignoff} />
        </p>
      </Reveal>
      <Figure
        src={gtcEarlyTalks.src}
        alt={gtcEarlyTalks.alt}
        caption={gtcEarlyTalks.caption}
        delay={gtcEarlyTalks.delay}
      />
    </div>
  </Section>

  <Section tone="parchment" space="md">
    <Reveal as="div" mode="up">
      <h2 id="explore-marks-story" class="font-display text-2xl text-[var(--color-midnight-900)] sm:text-3xl">
        {t.exploreHeading}
      </h2>
      <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {exploreCards.map((card) => (
          <li>
            <a class="block rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-gold-500)]" href={card.href}>
              <span class="font-display text-xl text-[var(--color-midnight-900)]" set:html={card.title} />
              <span class="mt-1 block font-text text-[var(--color-muted)]">{card.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </Reveal>
  </Section>

  <Section tone="paper" space="md">
    <MarketplaceCTA heading={t.marketplaceCTAHeading} />
  </Section>
</BaseLayout>
