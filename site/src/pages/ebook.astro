---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MarketplaceCTA from '@/components/MarketplaceCTA.astro';
import { Image } from 'astro:assets';
import { SITE } from '@/lib/site';
import { getEntry } from 'astro:content';

const PATH = '/ebook';

const page = (await getEntry('pageContent', 'ebook'))!;
const t = page.data.text!;

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Tolkien Collector’s Guide E-book', url: PATH },
];

const subject = encodeURIComponent('Free Tolkien Collector’s Guide e-book');
const mailto = `mailto:${SITE.email}?subject=${subject}`;
---
<BaseLayout
  title={page.data.seo!.title!}
  description={page.data.seo!.description!}
>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <div class="mt-8 grid grid-cols-1 gap-10 lg:grid-cols-[1.4fr_1fr] lg:items-center">
      <Reveal class="max-w-2xl">
        <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
          {t.heroEyebrow}
        </p>
        <h1 class="mt-3 font-display text-4xl text-[var(--color-parchment)] sm:text-5xl">
          {t.heroH1}
        </h1>
        <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/85">
          {t.heroIntro}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={mailto} variant="gold" size="lg">{t.ctaEmailMark}</Button>
        </div>
      </Reveal>
      <Reveal mode="fade" delay={120}>
        <figure class="overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/30">
          <Image
            src={page.data.heroImage!}
            alt={page.data.heroImageAlt!}
            widths={[400, 700]}
            sizes="(min-width: 1024px) 30vw, 100vw"
            class="w-full object-cover"
          />
        </figure>
      </Reveal>
    </div>
  </Section>

  <Section tone="paper" width="prose">
    <Reveal>
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
        {t.fromIntroEyebrow}
      </p>
      <h2 class="mt-3 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        {t.noteFromMarkH2}
      </h2>
      <div class="mt-6 space-y-5 font-text text-lg leading-relaxed text-[var(--color-text)]">
        <p>
          {t.noteP1}
        </p>
        <p>
          {t.noteP2}
        </p>
        <p>
          {t.noteP3}
        </p>
      </div>
    </Reveal>
  </Section>

  <Section tone="parchment" width="prose" space="md">
    <Reveal>
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        {t.howToGetH2}
      </h2>
      <ol class="mt-6 space-y-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
        <li>
          <span class="font-ui text-sm font-semibold uppercase tracking-wide text-[var(--color-gold-600)]">{t.step1Label}</span>
          <Fragment set:html={(t.step1Body as string).replace('{mailto}', mailto)} />
        </li>
        <li>
          <span class="font-ui text-sm font-semibold uppercase tracking-wide text-[var(--color-gold-600)]">{t.step2Label}</span>
          {t.step2Body}
        </li>
        <li>
          <span class="font-ui text-sm font-semibold uppercase tracking-wide text-[var(--color-gold-600)]">{t.step3Label}</span>
          {t.step3Body}
        </li>
      </ol>
      <div class="mt-8">
        <Button href={mailto} variant="primary" size="lg">{t.ctaRequestEbook}</Button>
      </div>
    </Reveal>
  </Section>

  <Section tone="surface" space="md">
    <MarketplaceCTA heading={t.marketplaceCTAHeading as string} tone="paper" />
  </Section>
</BaseLayout>
