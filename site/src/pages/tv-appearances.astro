---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import Figure from '@/components/story/Figure.astro';
import { article } from '@/lib/schema';
import { EXTERNAL } from '@/lib/site';
import { getEntry } from 'astro:content';

const page = (await getEntry('pageContent', 'tv-appearances'))!;
const t = page.data.text!;
const fig = (k: string) => page.data.figures!.find((f) => f.key === k)!;
const pawnStarsSet = fig('pawnStarsSet');
const thankYouCard = fig('thankYouCard');

const title = page.data.seo!.title!;
const description = page.data.seo!.description!;

const trail = [
  { name: 'Home', url: '/' },
  { name: 'TV Appearances', url: '/tv-appearances' },
];

const datePublished = '2024-01-01';
const dateModified = '2026-07-02';
const dateFormat = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const lastUpdated = dateFormat.format(new Date(dateModified));

const schema = article({
  title,
  description,
  url: '/tv-appearances',
  datePublished,
  dateModified,
});
---
<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedTime={datePublished}
  modifiedTime={dateModified}
  schema={schema}
>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <div class="mt-10 grid items-center gap-12 lg:grid-cols-[1.4fr_1fr]">
      <Reveal as="header" mode="up">
        <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">{t.heroEyebrow}</p>
        <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
          {t.heroH1}
        </h1>
        <p class="mt-6 max-w-prose font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
          {t.heroIntro}
        </p>
        <p class="mt-6 font-ui text-sm text-[var(--color-parchment)]/70">
          By Mark Faith · Last updated: <time datetime={dateModified}>{lastUpdated}</time>
        </p>
      </Reveal>
      <Figure
        src={pawnStarsSet.src}
        alt={pawnStarsSet.alt}
        caption={pawnStarsSet.caption}
        delay={pawnStarsSet.delay}
      />
    </div>
  </Section>

  <Section space="lg">
    <div class="prose-paper max-w-3xl">
      <Reveal as="div" mode="up">
        <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.fourRoomsH2}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.fourRoomsP1}
        </p>
      </Reveal>

      <Reveal as="div" mode="up" class="mt-10">
        <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.pawnStarsH2}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.pawnStarsP1}
        </p>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.pawnStarsP2}
        </p>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.pawnStarsP3}
        </p>
      </Reveal>

      <Reveal as="div" mode="up" class="mt-10">
        <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.moreMediaH2}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.moreMediaP1}
        </p>
      </Reveal>

      <Reveal as="div" mode="up" class="mt-8">
        <Figure
          src={thankYouCard.src}
          alt={thankYouCard.alt}
          caption={thankYouCard.caption}
          delay={thankYouCard.delay}
        />
      </Reveal>

      <Reveal as="div" mode="up" class="mt-10 not-prose">
        <p class="font-text text-lg text-[var(--color-text)]">
          {t.closingP}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={EXTERNAL.youtube} variant="gold" external>{t.ctaYouTube as string}</Button>
          <Button href="/news-media" variant="ghost">{t.ctaPress}</Button>
          <Button href="/contact" variant="ghost">{t.ctaContact}</Button>
        </div>
      </Reveal>
    </div>
  </Section>
</BaseLayout>
