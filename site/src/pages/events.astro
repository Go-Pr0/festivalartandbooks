---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import { collectionPage } from '@/lib/schema';

interface EventEntry {
  date: string;
  location: string;
  detail: string;
}

const title = 'Events: Tolkien Exhibitions & Talks by Mark Faith | Festival Art & Books';
const description =
  'Past and occasional Tolkien events from Festival Art and Books: rare books, art exhibitions ' +
  'and talks in Wales, the Netherlands and Scotland, with new events planned.';

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Events', url: '/events' },
];

const events: EventEntry[] = [
  {
    date: '14th November',
    location: 'Metropolis — Nazareth VIP gig / DVD launch',
    detail:
      'Iconic British rock band Nazareth announce a VIP gig and DVD launch featuring renowned ' +
      'Tolkien-inspired artist Rodney Matthews, who designed the sleeve artwork for the ' +
      'forthcoming Nazareth DVD release. Rodney gave a talk on the day about his art, with an ' +
      'exhibition of his work at Metropolis for one month covering a range of his rock album ' +
      'covers, including his seminal artwork for Nazareth’s 1978 album ‘No Mean City’.',
  },
  {
    date: '11th – 18th November',
    location: 'Artist Gallery, 403 Holburn Street, Aberdeen',
    detail:
      'Festival in the Shire Exhibition returns to Scotland. A celebration of fantasy art ' +
      'including classic rock album covers from Roger Dean and Rodney Matthews, with album covers ' +
      'for the bands YES, ASIA, Uriah Heap, Nazareth, Magnum and other classic rock bands as well ' +
      'as art for books, posters and calendars. Artist signed prints and posters were available ' +
      'for sale alongside Tolkien books and memorabilia. Rodney Matthews gave a free talk about ' +
      'his art on Tuesday 12th at 6:30pm and again on Saturday 16th at 6:30pm at the Artist ' +
      'Gallery. Other fantasy artist works on display included Roger Dean, Rainer Kalwit, Ruth ' +
      'Lacon, Joe Gilronan, Tim Kirk and Ted Nasmith.',
  },
];

const schema = collectionPage({
  name: 'Events — Festival Art & Books',
  description,
  url: '/events',
  items: events.map((e) => ({ name: `${e.date} — ${e.location}`, url: '/events' })),
});
---
<BaseLayout title={title} description={description} schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal as="div" mode="up" class="mt-10 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">Exhibitions &amp; talks</p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
        Events
      </h1>
      <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
        We have no Tolkien Rare Book events scheduled, but have plans to start them again soon.
        Watch this space. We sometimes exhibit at others’ events. If you would be interested in
        having us exhibit at your event, please contact us. Some past events are highlighted below.
        In addition, we organised our own very large event with over 500 attendees,
        <a class="underline decoration-[var(--color-gold-500)]/60 underline-offset-4" href="/festival-in-the-shire">Festival in the Shire</a> in 2010.
      </p>
    </Reveal>
  </Section>

  <Section space="md">
    <Reveal as="div" mode="up">
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">Past events</h2>
    </Reveal>
    <ol class="mt-8 space-y-6">
      {events.map((event, i) => (
        <Reveal as="li" mode="up" delay={i * 90}>
          <article class="grid gap-2 rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] p-6 sm:grid-cols-[12rem_1fr] sm:gap-6 sm:p-7">
            <div>
              <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">{event.date}</p>
              <p class="mt-1 font-display text-xl text-[var(--color-midnight-900)]">{event.location}</p>
            </div>
            <p class="font-text text-lg leading-relaxed text-[var(--color-text)]">{event.detail}</p>
          </article>
        </Reveal>
      ))}
    </ol>
  </Section>

  <Section tone="parchment" space="md">
    <Reveal as="div" mode="up" class="max-w-2xl">
      <h2 class="font-display text-2xl text-[var(--color-midnight-900)] sm:text-3xl">More events planned</h2>
      <p class="mt-3 font-text text-lg leading-relaxed text-[var(--color-text)]">
        Mark intends to stage new exhibitions and talks. To hear about the next one, or to discuss
        a private viewing of rare Tolkien books and art, get in touch.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <Button href="/festival-in-the-shire" variant="primary">About Festival in the Shire</Button>
        <Button href="/contact" variant="ghost">Register your interest</Button>
      </div>
      {/* TODO: Mark to confirm any confirmed dates/venues for upcoming events. */}
    </Reveal>
  </Section>
</BaseLayout>
