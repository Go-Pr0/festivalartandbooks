---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import { collectionPage } from '@/lib/schema';
import { getEntry, getCollection } from 'astro:content';

interface EventEntry {
  date: string;
  location: string;
  detail: string;
}

const page = (await getEntry('pageContent', 'events'))!;
const t = page.data.text!;

const title = page.data.seo!.title!;
const description = page.data.seo!.description!;

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Events', url: '/events' },
];

const events: EventEntry[] = (await getCollection('events'))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((e) => ({ date: e.data.date, location: e.data.location, detail: e.data.detail }));

const schema = collectionPage({
  name: 'Events — Festival Art & Books',
  description,
  url: '/events',
  items: events.map((e) => ({ name: `${e.date} — ${e.location}`, url: '/events' })),
});
---
<BaseLayout title={title} description={description} schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal as="div" mode="up" class="mt-10 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">{t.heroEyebrow}</p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
        {t.heroH1}
      </h1>
      <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
        <Fragment set:html={t.heroIntro} />
      </p>
    </Reveal>
  </Section>

  <Section space="md">
    <Reveal as="div" mode="up">
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">{t.pastEventsHeading}</h2>
    </Reveal>
    <ol class="mt-8 space-y-6">
      {events.map((event, i) => (
        <Reveal as="li" mode="up" delay={i * 90}>
          <article class="grid gap-2 rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] p-6 sm:grid-cols-[12rem_1fr] sm:gap-6 sm:p-7">
            <div>
              <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">{event.date}</p>
              <p class="mt-1 font-display text-xl text-[var(--color-midnight-900)]">{event.location}</p>
            </div>
            <p class="font-text text-lg leading-relaxed text-[var(--color-text)]">{event.detail}</p>
          </article>
        </Reveal>
      ))}
    </ol>
  </Section>

  <Section tone="parchment" space="md">
    <Reveal as="div" mode="up" class="max-w-2xl">
      <h2 class="font-display text-2xl text-[var(--color-midnight-900)] sm:text-3xl">{t.moreEventsHeading}</h2>
      <p class="mt-3 font-text text-lg leading-relaxed text-[var(--color-text)]">
        {t.moreEventsParagraph}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <Button href="/festival-in-the-shire" variant="primary">{t.ctaButtonFestival}</Button>
        <Button href="/contact" variant="ghost">{t.ctaButtonContact}</Button>
      </div>
      {/* TODO: Mark to confirm any confirmed dates/venues for upcoming events. */}
    </Reveal>
  </Section>
</BaseLayout>
