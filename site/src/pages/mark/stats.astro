---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';

const ACCESS_KEY = 'fab2026';
const authorized = Astro.url.searchParams.get('key') === ACCESS_KEY;
---
<BaseLayout title="Site Statistics" noindex={true}>
  {authorized ? (
    <Section tone="paper" width="prose" space="lg">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
        Private
      </p>
      <h1 class="mt-3 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        Site visit counter
      </h1>
      <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
        This page is for Mark Faith only. It shows the total number of site visits
        recorded since the counter was enabled. The count increments once per browser
        session across all public pages.
      </p>
      <p class="mt-8 font-display text-5xl text-[var(--color-midnight-900)]" id="visit-count">
        …
      </p>
      <p class="mt-2 font-ui text-sm text-[var(--color-muted)]">Total visits</p>
    </Section>
  ) : (
    <Section tone="paper" width="prose" space="lg">
      <h1 class="font-display text-3xl text-[var(--color-midnight-900)]">Not found</h1>
      <p class="mt-4 font-text text-lg text-[var(--color-muted)]">
        The page you are looking for does not exist.
      </p>
    </Section>
  )}
</BaseLayout>

{authorized && (
  <script>
    const GET_URL = 'https://api.countapi.xyz/get/festivalartandbooks.com/visits';
    const el = document.getElementById('visit-count');

    fetch(GET_URL)
      .then((res) => res.json())
      .then((data: { value?: number }) => {
        if (el && typeof data.value === 'number') {
          el.textContent = data.value.toLocaleString('en-GB');
        } else if (el) {
          el.textContent = '—';
        }
      })
      .catch(() => {
        if (el) el.textContent = 'Unavailable';
      });
  </script>
)}
