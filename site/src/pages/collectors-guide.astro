---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import { Image } from 'astro:assets';
import { collectionPage } from '@/lib/schema';
import { SITE } from '@/lib/site';
import { getEntry, getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const PATH = '/collectors-guide';

const page = (await getEntry('pageContent', 'collectors-guide'))!;
const t = page.data.text!;

const chapters = (await getCollection('guides', ({ data }) =>
  data.cluster === 'collectors-guide' && !data.draft,
)).sort(
  (a: CollectionEntry<'guides'>, b: CollectionEntry<'guides'>) =>
    (a.data.chapterOrder ?? 0) - (b.data.chapterOrder ?? 0),
);

const allGuides = await getCollection('guides', ({ data }) => !data.draft);

const identificationFallbacks = {
  'hobbit-first-edition-1937-identification': {
    title: 'Hobbit First Edition (1937) Identification',
    description:
      'Allen & Unwin first-edition points, dust-jacket variants, and how to tell a true 1937 Hobbit from later impressions.',
    cluster: 'hobbit-first-editions',
  },
  'lotr-first-edition-1954-55-identification': {
    title: 'Lord of the Rings First Edition (1954–55) Identification',
    description:
      'How to identify a genuine first-edition Lord of the Rings set — printings, jackets, and the details dealers check first.',
    cluster: 'lotr-first-editions',
  },
} as const;

function resolveIdentificationGuide(slug: keyof typeof identificationFallbacks) {
  const exact = allGuides.find((g) => g.id === slug);
  if (exact) return exact;
  const cluster = identificationFallbacks[slug].cluster;
  return allGuides.find((g) => g.data.cluster === cluster && g.data.pillar) ?? null;
}

const identificationGuides = (Object.keys(identificationFallbacks) as Array<
  keyof typeof identificationFallbacks
>).map((slug) => {
  const guide = resolveIdentificationGuide(slug);
  const fallback = identificationFallbacks[slug];
  return {
    href: `/guides/${guide?.id ?? slug}`,
    title: guide?.data.title ?? fallback.title,
    description: guide?.data.description ?? fallback.description,
  };
});

const title = page.data.seo!.title!;
const description = page.data.seo!.description!;

const trail = [
  { name: 'Home', url: '/' },
  { name: "The Tolkien Collector's Guide", url: PATH },
];

const firstChapter = chapters[0];
const pdfSubject = encodeURIComponent("Tolkien Collector's Guide PDF");
const mailto = `mailto:${SITE.email}?subject=${pdfSubject}`;

const schema = collectionPage({
  name: "The Tolkien Collector's Guide",
  description,
  url: PATH,
  items: chapters.map((ch) => ({ name: ch.data.title, url: `/guides/${ch.id}` })),
});
---
<BaseLayout title={title} description={description} image="/og/guides.jpg" schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <div class="mt-8 grid grid-cols-1 gap-10 lg:grid-cols-[1.4fr_1fr] lg:items-center">
      <Reveal class="max-w-2xl">
        <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
          {t.heroEyebrow}
        </p>
        <h1 class="mt-3 font-display text-4xl text-[var(--color-parchment)] sm:text-5xl">
          {t.heroH1}
        </h1>
        <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/85">
          {t.heroIntro}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {firstChapter && (
            <Button href={`/guides/${firstChapter.id}`} variant="gold" size="lg">
              {t.ctaReadOnline}
            </Button>
          )}
          <Button href={mailto} variant="ghost" size="lg" class="text-[var(--color-parchment)] border-[var(--color-parchment)]/40 hover:bg-[var(--color-parchment)]/10">
            {t.ctaDownload}
          </Button>
        </div>
      </Reveal>
      {page.data.heroImage && (
        <Reveal mode="fade" delay={120}>
          <figure class="overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/30">
            <Image
              src={page.data.heroImage}
              alt={page.data.heroImageAlt!}
              widths={[400, 700]}
              sizes="(min-width: 1024px) 30vw, 100vw"
              class="w-full object-cover"
            />
          </figure>
        </Reveal>
      )}
    </div>
  </Section>

  <Section space="lg">
    <Reveal as="header">
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        {t.chaptersHeading}
      </h2>
    </Reveal>
    {chapters.length > 0 ? (
      <ul class="mt-8 grid gap-8 sm:grid-cols-2">
        {chapters.map((chapter, i) => (
          <Reveal as="li" delay={i * 80}>
            <a
              href={`/guides/${chapter.id}`}
              class="group flex h-full flex-col overflow-hidden rounded-sm border border-[var(--color-gold-600)]/20 bg-[var(--color-surface)] transition-colors hover:border-[var(--color-gold-600)]/50"
            >
              {chapter.data.heroImage && (
                <Image
                  src={chapter.data.heroImage}
                  alt={chapter.data.heroAlt ?? chapter.data.title}
                  widths={[400, 700]}
                  sizes="(min-width: 640px) 50vw, 100vw"
                  class="aspect-[16/9] w-full object-cover"
                />
              )}
              <div class="flex flex-1 flex-col p-6">
                {chapter.data.chapterOrder != null && (
                  <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
                    Chapter {chapter.data.chapterOrder + 1}
                  </p>
                )}
                <h3 class="mt-2 font-display text-2xl text-[var(--color-midnight-900)] group-hover:text-[var(--color-oxblood-600)]">
                  {chapter.data.title}
                </h3>
                <p class="mt-3 flex-1 text-[var(--color-muted)]">{chapter.data.description}</p>
                <span class="mt-4 font-ui text-sm text-[var(--color-oxblood-600)]">
                  Read chapter →
                </span>
              </div>
            </a>
          </Reveal>
        ))}
      </ul>
    ) : (
      <Reveal class="mt-8 max-w-2xl">
        <p class="font-text text-lg text-[var(--color-muted)]">
          Chapters are being published. Email{' '}
          <a class="text-[var(--color-oxblood-600)] underline" href={mailto}>{SITE.email}</a>{' '}
          for the PDF edition in the meantime.
        </p>
      </Reveal>
    )}
  </Section>

  <Section tone="parchment" space="md">
    <Reveal as="header" class="max-w-2xl">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
        First-edition identification
      </p>
      <h2 class="mt-3 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        Identification guides
      </h2>
      <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-muted)]">
        Ready to verify a copy before you buy? These cornerstone guides walk through the
        identification points dealers use for Tolkien&apos;s two most collected first editions.
      </p>
    </Reveal>
    <ul class="mt-8 grid gap-6 sm:grid-cols-2">
      {identificationGuides.map((guide, i) => (
        <Reveal as="li" delay={i * 80}>
          <a
            href={guide.href}
            class="group flex h-full flex-col rounded-[var(--radius)] border border-[var(--color-gold-600)]/30 bg-[var(--color-surface)] p-6 transition-colors hover:border-[var(--color-gold-500)]"
          >
            <h3 class="font-display text-2xl text-[var(--color-midnight-900)] group-hover:text-[var(--color-oxblood-600)]">
              {guide.title}
            </h3>
            <p class="mt-3 flex-1 text-[var(--color-muted)]">{guide.description}</p>
            <span class="mt-4 font-ui text-sm text-[var(--color-oxblood-600)]">
              Read the guide →
            </span>
          </a>
        </Reveal>
      ))}
    </ul>
  </Section>
</BaseLayout>
