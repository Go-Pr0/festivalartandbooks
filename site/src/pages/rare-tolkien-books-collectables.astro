---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MarketplaceCTA from '@/components/MarketplaceCTA.astro';
import Gallery from '@/components/showcase/Gallery.astro';
import type { GalleryItem } from '@/components/showcase/Gallery.astro';
import { Image } from 'astro:assets';
import { collectionPage } from '@/lib/schema';

import heroMontage from '@/assets/showcase/tolkien-rare-books-collection-montage.jpg';
import firstFourHobbit from '@/assets/showcase/tolkien-hobbit-first-four-editions.jpg';
import booksMontage from '@/assets/showcase/tolkien-first-edition-books-montage.jpg';
import hobbitCovers from '@/assets/showcase/tolkien-hobbit-vintage-editions-covers.jpg';

const PATH = '/rare-tolkien-books-collectables';

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Rare Tolkien Books & Collectables', url: PATH },
];

const gallery: GalleryItem[] = [
  {
    src: firstFourHobbit,
    alt: 'Four vintage hardback editions of The Hobbit by J.R.R. Tolkien with dust jackets',
    caption: 'Early hardback editions of The Hobbit: condition and complete dust jackets are everything.',
  },
  {
    src: booksMontage,
    alt: 'Montage of rare first-edition Tolkien hardbacks including The Lord of the Rings titles',
    caption: 'First and early printings of The Hobbit and The Lord of the Rings.',
  },
  {
    src: hobbitCovers,
    alt: 'Vintage dust jacket cover art from collectable editions of The Hobbit',
    caption: 'Collectable dust jackets across decades of Hobbit printings.',
  },
];

const schema = collectionPage({
  name: 'Rare Tolkien Books & Collectables',
  description:
    'A showcase of the rare and collectable J.R.R. Tolkien books Mark Faith deals in: ' +
    'first and early printings of The Hobbit and The Lord of the Rings, plus posters and memorabilia.',
  url: PATH,
  items: gallery.map((item) => ({ name: item.alt, url: PATH })),
});
---
<BaseLayout
  title="Rare Tolkien Books & Collectables | Festival Art & Books"
  description="Rare Tolkien books are the first and early printings of The Hobbit and The Lord of the Rings. Mark Faith deals in fine, complete first editions, posters and memorabilia."
  schema={schema}
>
  <Section tone="midnight" space="md" contained={false} class="relative overflow-hidden">
    <Image
      src={heroMontage}
      alt="Collection of rare J.R.R. Tolkien first-edition books, posters and memorabilia"
      widths={[800, 1400, 2000]}
      sizes="100vw"
      class="absolute inset-0 h-full w-full object-cover opacity-25"
    />
    <div class="relative mx-auto w-full max-w-[var(--page-max)] px-6 sm:px-8">
      <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
      <Reveal class="mt-8 max-w-3xl">
        <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
          The Collection
        </p>
        <h1 class="mt-3 font-display text-4xl text-[var(--color-parchment)] sm:text-6xl">
          Rare Tolkien Books &amp; Collectables
        </h1>
        <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/85">
          “Rare Tolkien books” mostly means the first and early printings of the very first
          editions ever sold to the public, chiefly The Hobbit (1937) and The Lord of the
          Rings (1954–55). A serious collection can run to hundreds or even a thousand books,
          plus posters and memorabilia.
        </p>
      </Reveal>
    </div>
  </Section>

  <Section tone="paper" width="prose">
    <Reveal>
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
        What we deal in
      </p>
      <h2 class="mt-3 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        First and early printings, chosen for condition
      </h2>
      <div class="mt-6 space-y-5 font-text text-lg leading-relaxed text-[var(--color-text)]">
        <p>
          The most collected titles are The Hobbit and The Lord of the Rings, and the
          hundreds of printings and new editions of just those titles. They have never
          been out of print, and Tolkien collecting is now so popular that any edition,
          in any language, is collected somewhere in the world, not only in the
          English-speaking one.
        </p>
        <p>
          Newer editions can be collectable too, especially deluxe editions with small
          print runs, but they are not expensive to buy. The pieces we handle are the
          fine, complete copies: the older the printing and the closer it is to the
          first, the more it is worth, provided it is complete with its dust jacket and
          shows no damage beyond normal wear. The same book in the same printing can be
          worth £50 or £5,000 depending entirely on condition. There are plenty of worn
          books; it is the fine ones that are truly rare.
        </p>
      </div>
    </Reveal>
  </Section>

  <Section tone="parchment">
    <Reveal>
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        A look at the kinds of pieces Mark handles
      </h2>
      <p class="mt-3 max-w-2xl font-text text-lg text-[var(--color-muted)]">
        A showcase of the rare books and collectables we deal in. Live stock, with
        photographs and condition shown openly, is on the marketplace shops below.
      </p>
    </Reveal>
    <Gallery items={gallery} columns={3} class="mt-10" />
  </Section>

  <Section tone="paper" width="prose">
    <Reveal class="rounded-[var(--radius)] border border-[var(--color-gold-600)]/30 bg-[var(--color-surface)] p-8 sm:p-10">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
        Go deeper
      </p>
      <h2 class="mt-3 font-display text-2xl text-[var(--color-midnight-900)] sm:text-3xl">
        Collecting Tolkien books for fun and investment
      </h2>
      <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
        Collecting Tolkien is a tale of modern, not antiquarian, book collecting: an
        enjoyable hobby with very few pitfalls, where editions range from £10 to half a
        million or more. Mark’s full guide covers condition, impressions and dust-jacket
        wear, market supply and demand, values and investment: everything you need to
        buy correctly.
      </p>
      <div class="mt-6">
        <Button href="/guides" variant="gold">Read the full collecting &amp; investment guide</Button>
      </div>
    </Reveal>
  </Section>

  <Section tone="surface">
    <MarketplaceCTA
      heading="Browse rare Tolkien books for sale"
      tone="paper"
    />
  </Section>
</BaseLayout>
