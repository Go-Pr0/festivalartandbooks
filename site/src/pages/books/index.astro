---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import BookCard from '@/components/books/BookCard.astro';
import CatalogueToolbar from '@/components/books/CatalogueToolbar.astro';
import { collectionPage } from '@/lib/schema';

const allBooks = await getCollection('books', ({ data }) => !data.draft && data.availability !== 'OutOfStock');
const books = allBooks.sort((a: CollectionEntry<'books'>, b: CollectionEntry<'books'>) =>
  a.data.title.localeCompare(b.data.title),
);

const prices = books
  .map((b) => b.data.price)
  .filter((p): p is number => p != null);
const minPrice = prices.length > 0 ? Math.min(...prices) : 0;
const maxPrice = prices.length > 0 ? Math.max(...prices) : 0;

const title = 'ONLINE SHOP';
const description =
  'Rare Tolkien Books for Sale from Festival Art and Books. Browse our inventory today.';

const schema = collectionPage({
  name: title,
  description,
  url: '/books',
  items: books.map((b) => ({ name: b.data.title, url: `/books/${b.id}` })),
});
---
<BaseLayout title={title} description={description} schema={schema}>
  <Section tone="midnight" space="sm" class="!pb-4 sm:!pb-5">
    <Breadcrumbs
      class="!text-[var(--color-parchment)]/70"
      trail={[
        { name: 'Home', url: '/' },
        { name: 'Current Catalogue', url: '/books' },
      ]}
    />
    <header class="mt-4 max-w-[var(--content-max)]">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
        Current Catalogue
      </p>
      <h1 class="mt-2 font-display text-3xl leading-tight text-[var(--color-parchment)] sm:text-4xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-[var(--color-parchment)]/80 sm:text-xl">
        Please visit our Ebay or AbeBooks shops. We have 100% positive feedback on both.
      </p>
    </header>
  </Section>

  <Section space="md" class="!pt-5 sm:!pt-6">
    {books.length > 0 ? (
      <>
        <CatalogueToolbar totalCount={books.length} minPrice={minPrice} maxPrice={maxPrice} />
        <p
          id="catalogue-empty"
          class="hidden font-text text-lg text-[var(--color-muted)]"
          hidden
        >
          No items match your filters. Try adjusting your search or price range.
        </p>
        <ul id="catalogue-grid" class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {books.map((b) => (
            <li
              data-price={b.data.price ?? ''}
              data-kind={b.data.kind}
              data-title={b.data.title}
              data-search-text={`${b.data.title} ${b.data.description}`.toLowerCase()}
            >
              <BookCard
                slug={b.id}
                title={b.data.title}
                description={b.data.description}
                editionTitle={b.data.editionTitle}
                price={b.data.price}
                priceCurrency={b.data.priceCurrency}
                firstImage={b.data.images?.[0]}
              />
            </li>
          ))}
        </ul>
      </>
    ) : (
      <Reveal class="max-w-[var(--content-max)]">
        <p class="text-xl text-[var(--color-muted)]">
          No items are listed at the moment. Mark's stock changes regularly —
          check back soon, or <a href="/contact">contact him directly</a> to
          discuss what you're looking for.
        </p>
      </Reveal>
    )}
  </Section>
</BaseLayout>

{books.length > 0 && (
  <script>
    import { setupCatalogueFilter } from '@/scripts/catalogue-filter';
    setupCatalogueFilter();
  </script>
)}
