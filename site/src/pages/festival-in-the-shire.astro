---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import Figure from '@/components/story/Figure.astro';
import { article } from '@/lib/schema';
import { getEntry } from 'astro:content';

const page = (await getEntry('pageContent', 'festival-in-the-shire'))!;
const t = page.data.text!;
const fig = (k: string) => page.data.figures!.find((f) => f.key === k)!;
const montageOne = fig('montageOne');
const montageTwo = fig('montageTwo');

const title = page.data.seo!.title!;
const description = page.data.seo!.description!;

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Festival in the Shire', url: '/festival-in-the-shire' },
];

const schema = article({
  title,
  description,
  url: '/festival-in-the-shire',
  datePublished: '2024-01-01',
  dateModified: '2026-06-25',
});
---
<BaseLayout title={title} description={description} type="article" schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal as="div" mode="up" class="mt-10 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">{t.heroEyebrow}</p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
        {t.heroH1}
      </h1>
      <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
        {t.heroIntro}
      </p>
    </Reveal>
  </Section>

  <Section space="lg">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:items-start">
      <Reveal as="div" mode="up" class="prose-paper">
        <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.whatWasH2}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.whatWasP1}
        </p>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.whatWasP2}
        </p>

        <h2 class="mt-10 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.whatHappenedH2}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.whatHappenedP1}
        </p>

        <h2 class="mt-10 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          {t.willReturnH2}
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {t.willReturnP1}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href="/events" variant="primary">{t.ctaEvents}</Button>
          <Button href="/contact" variant="ghost">{t.ctaContact}</Button>
        </div>
        {/* TODO: Mark to confirm whether to link the original event site/schedules
            (festivalartandbooks.com/FAB/FitS/) or treat them as archived/retired. */}
      </Reveal>

      <div class="space-y-8">
        <Figure
          src={montageOne.src}
          alt={montageOne.alt}
          caption={montageOne.caption}
          frame={montageOne.frame as 'default' | 'portrait'}
          delay={montageOne.delay}
        />
        <Figure
          src={montageTwo.src}
          alt={montageTwo.alt}
          caption={montageTwo.caption}
          delay={montageTwo.delay}
        />
      </div>
    </div>
  </Section>
</BaseLayout>
