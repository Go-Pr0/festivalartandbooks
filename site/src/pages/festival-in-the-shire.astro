---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import Figure from '@/components/story/Figure.astro';
import { article } from '@/lib/schema';

import montageOne from '@/assets/story/festival-in-the-shire-2010-event-montage.jpg';
import montageTwo from '@/assets/story/festival-in-the-shire-2010-event-montage-two.jpg';

const title = 'Festival in the Shire: Mark Faith’s 2010 Tolkien Festival | Festival Art & Books';
const description =
  'Festival in the Shire was a three-day Tolkien festival created by Mark Faith in 2010, with ' +
  '500+ attendees, expert lectures, an art show and a fan exposition. Plans to revive it.';

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Festival in the Shire', url: '/festival-in-the-shire' },
];

const schema = article({
  title,
  description,
  url: '/festival-in-the-shire',
  datePublished: '2024-01-01',
  dateModified: '2026-06-25',
});
---
<BaseLayout title={title} description={description} type="article" schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal as="div" mode="up" class="mt-10 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">2010 · Mid-Wales</p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
        Festival in the Shire
      </h1>
      <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
        Festival in the Shire was one of the biggest Tolkien events of 2010, created and staged by
        Mark Faith of Festival Art and Books. Held over three days with more than 500 attendees, it
        brought together academic Tolkien experts giving lectures, an art show, stalls,
        entertainment and a fan exposition. It was both a major event for fans and a focal point for
        worldwide collectors of Tolkien books and Tolkien-inspired art.
      </p>
    </Reveal>
  </Section>

  <Section space="lg">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:items-start">
      <Reveal as="div" mode="up" class="prose-paper">
        <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          What was Festival in the Shire?
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          One of the biggest Tolkien events in 2010 was Festival in the Shire. With over 500
          attendees and held over three days, there was a comprehensive cast of academic Tolkien
          experts giving lectures, with an art show, stalls, entertainment and a fan exposition.
        </p>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          This was not just about collecting Tolkien Rare Books, but a journey into the amazing
          writing and the author himself.
        </p>

        <h2 class="mt-10 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          What happened after?
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          For three years afterwards, Mark held smaller local events, including one in Scotland and
          another in the Netherlands, followed by occasional book and art exhibitions. He continues
          to hold small exhibitions and fan events, both for fans and for serious collectors.
        </p>

        <h2 class="mt-10 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
          Will the festival return?
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          Yes, there are plans to stage these events again. As a new cycle of Tolkien film and
          fandom begins, keep an eye on this site for announcements.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href="/events" variant="primary">See past &amp; upcoming events</Button>
          <Button href="/contact" variant="ghost">Register your interest</Button>
        </div>
        {/* TODO: Mark to confirm whether to link the original event site/schedules
            (festivalartandbooks.com/FAB/FitS/) or treat them as archived/retired. */}
      </Reveal>

      <div class="space-y-8">
        <Figure
          src={montageOne}
          alt="Photo montage from Festival in the Shire 2010 showing community events, performances and exhibitions"
          caption="A montage from Festival in the Shire 2010: lectures, art, stalls and entertainment over three days."
          frame="portrait"
          delay={80}
        />
        <Figure
          src={montageTwo}
          alt="Further photo montage from Festival in the Shire 2010 capturing attendees and exhibition stands"
          caption="More from the festival weekend: 500+ attendees gathered for the celebration."
          delay={160}
        />
      </div>
    </div>
  </Section>
</BaseLayout>
