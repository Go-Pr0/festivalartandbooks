---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import StatBand from '@/components/StatBand.astro';
import type { StatItem } from '@/components/StatBand.astro';
import MarketplaceCTA from '@/components/MarketplaceCTA.astro';
import Hero from '@/components/home/Hero.astro';
import TrustCard from '@/components/home/TrustCard.astro';
import DealsInCard from '@/components/home/DealsInCard.astro';
import { SITE } from '@/lib/site';

import collectionImage from '@/assets/home/tolkien-rare-books-collectables-montage.jpg';
import hobbitImage from '@/assets/home/tolkien-hobbit-1937-first-edition-copies.jpg';
import collectionMontageImage from '@/assets/home/tolkien-first-edition-collection-montage.jpg';

const description =
  'Festival Art & Books is one of the world’s oldest and largest J.R.R. Tolkien rare-book ' +
  'dealerships, with 25+ years selling first editions of The Hobbit and The Lord of the Rings, in stock.';

const stats: StatItem[] = [
  { value: 25, suffix: '+', label: 'Years specialising in Tolkien' },
  { value: 300000, prefix: '£', label: 'Highest Hobbit first edition sold' },
  { value: 100, suffix: '%', label: 'Positive feedback' },
];

interface TrustPoint {
  heading: string;
  body: string;
}

const trustPoints: TrustPoint[] = [
  {
    heading: 'In stock, not brokered',
    body: 'I always hold the rarest Tolkien books in stock, ready to buy, with no sold-out listings or non-existent loss-leaders used to draw you in.',
  },
  {
    heading: '100% positive feedback',
    body: 'A quarter-century of customers and an unbroken record of positive feedback. As a specialist I have to get it right, every time, for every collector.',
  },
  {
    heading: 'I set the market',
    body: 'As one of the pioneering dealers when the films arrived, I have always been the first to predict new price levels, and I helped create this market.',
  },
  {
    heading: 'Buy direct, save the fees',
    body: 'Items are listed on eBay and AbeBooks, but contact me directly to purchase. You deal with the dealer himself and avoid the marketplace fees.',
  },
];
---
<BaseLayout description={description}>
  <Hero
    title="Festival Art & Books"
    subtitle="Tolkien Rare Books"
    positioning="One of the oldest and largest Tolkien rare-book dealerships in the world."
  />

  <!-- Welcome / positioning -->
  <Section width="prose">
    <Reveal class="prose-paper">
      <p class="font-ui text-xs uppercase tracking-[0.24em] text-[var(--color-gold-600)]">
        Welcome
      </p>
      <h2 id="about-mark" class="mt-4 font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        I have specialised in selling rare Tolkien books for 25 years.
      </h2>
      <p class="mt-6 font-text text-xl leading-relaxed">
        I am not a general bookseller, and I have no other day job. I sell only
        J.R.R. Tolkien collectable books, and I am recognised as a leading expert on
        rare Tolkien books, Tolkien collecting and investment. Tolkien scholars and
        general book dealers, even older ones, are not Tolkien rare-book experts.
      </p>
      <p class="mt-5 font-text text-lg leading-relaxed text-[var(--color-muted)]">
        I have sold some of the rarest and most expensive first editions ever, and have
        always been the first to predict new price levels. I know the market, having
        helped to create it as one of the pioneering dealers when the new films came out.
        I even set up a Tolkien museum in Switzerland. I always have the most, and the
        best, copies for sale at any given point. Your time matters: buy the best, from
        the best.
      </p>
    </Reveal>
  </Section>

  <!-- Stat band -->
  <Section tone="midnight" space="md">
    <Reveal>
      <p class="text-center font-ui text-xs uppercase tracking-[0.24em] text-[var(--color-gold-300)]">
        Twenty-five years on record
      </p>
    </Reveal>
    <div class="mt-10">
      <StatBand stats={stats} tone="light" />
    </div>
  </Section>

  <!-- Why buy from Mark -->
  <Section tone="parchment">
    <Reveal class="max-w-2xl">
      <h2 id="why-buy-from-mark" class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        Why collectors buy from Mark
      </h2>
      <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-muted)]">
        With record prices being achieved by Tolkien first editions, accurate, truthful
        advice matters more than ever. Here is what sets this dealership apart.
      </p>
    </Reveal>
    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {trustPoints.map((point, i) => (
        <Reveal delay={i * 90}>
          <TrustCard heading={point.heading} body={point.body} />
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- What he deals in -->
  <Section>
    <Reveal class="max-w-2xl">
      <h2 id="what-i-deal-in" class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        What I deal in
      </h2>
      <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-muted)]">
        First editions of The Hobbit and The Lord of the Rings, signed and association
        copies, and rare collectables, alongside guidance on building a collection.
      </p>
    </Reveal>
    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      <Reveal delay={0}>
        <DealsInCard
          image={hobbitImage}
          alt="First-edition copies of J.R.R. Tolkien's The Hobbit (1937) side by side"
          heading="The Hobbit, 1937"
          body="First editions and early impressions of Tolkien's debut: the cornerstone of any serious collection."
          href="/rare-tolkien-books-collectables"
          cta="See the collection"
        />
      </Reveal>
      <Reveal delay={90}>
        <DealsInCard
          image={collectionMontageImage}
          alt="Montage of J.R.R. Tolkien first-edition books and Lord of the Rings sets"
          heading="Lord of the Rings sets"
          body="First-edition sets of the 1954–55 trilogy, including signed and exceptional copies."
          href="/rare-tolkien-books-collectables"
          cta="See the collection"
        />
      </Reveal>
      <Reveal delay={180}>
        <DealsInCard
          image={collectionImage}
          alt="Montage of rare and collectable Tolkien books and ephemera"
          heading="Rare books & guides"
          body="Collectables, ephemera and the knowledge to collect well. Start with my free collector guides."
          href="/guides"
          cta="Read the guides"
        />
      </Reveal>
    </div>
  </Section>

  <!-- Free e-book + newsletter -->
  <Section tone="surface">
    <div class="grid gap-10 lg:grid-cols-2">
      <Reveal class="rounded-[var(--radius)] border border-[var(--color-gold-600)]/30 bg-[var(--color-parchment-dim)] p-8 sm:p-10">
        <p class="font-ui text-xs uppercase tracking-[0.24em] text-[var(--color-gold-600)]">
          New in 2026 · Free
        </p>
        <h2 class="mt-4 font-display text-3xl text-[var(--color-midnight-900)]">
          The Tolkien Collectors Guide
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-muted)]">
          A free 26-page e-book written by Mark Faith with general advice on collecting
          Tolkien first editions and other rare and collectable Tolkien books. For
          specifics on what to buy and the best investment strategy, I offer free
          personal advice.
        </p>
        <div class="mt-7">
          <Button href="/ebook" variant="gold">Get the free e-book</Button>
        </div>
      </Reveal>

      <Reveal delay={90} class="rounded-[var(--radius)] border border-[var(--color-gold-600)]/30 bg-[var(--color-parchment-dim)] p-8 sm:p-10">
        <p class="font-ui text-xs uppercase tracking-[0.24em] text-[var(--color-gold-600)]">
          Free newsletter
        </p>
        <h2 class="mt-4 font-display text-3xl text-[var(--color-midnight-900)]">
          Stay close to the market
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-muted)]">
          I send a free newsletter on collecting J.R.R. Tolkien rare books, keyed to the
          latest news and market developments, more frequent through Autumn and Spring,
          the busier buying periods. Contact me directly with any questions at any time.
        </p>
        <div class="mt-7">
          <Button
            href={`mailto:${SITE.email}?subject=Subscribe%20to%20the%20Festival%20Art%20%26%20Books%20newsletter`}
            variant="ghost"
          >
            Subscribe by email
          </Button>
        </div>
      </Reveal>
    </div>
  </Section>

  <!-- Authoritative-source note (GEO) -->
  <Section tone="midnight" space="md" width="prose">
    <Reveal class="text-center">
      <h2 id="the-accurate-source" class="font-display text-2xl text-[var(--color-gold-300)] sm:text-3xl">
        The accurate source on collecting Tolkien
      </h2>
      <p class="mx-auto mt-5 max-w-2xl font-text text-lg leading-relaxed text-[var(--color-parchment)]/85">
        In the last five years there has been a marked decline in the accuracy and quality
        of search-engine and AI results on collecting Tolkien books. This site exists to be
        the accurate, authoritative source, from a dealer who has helped shape the market
        for 25 years.
      </p>
    </Reveal>
  </Section>

  <!-- Marketplace CTA -->
  <Section space="md">
    <Reveal>
      <MarketplaceCTA heading="Browse the collection" />
    </Reveal>
  </Section>
</BaseLayout>
