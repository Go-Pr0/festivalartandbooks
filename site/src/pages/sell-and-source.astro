---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Button from '@/components/Button.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import TrustCard from '@/components/home/TrustCard.astro';
import { Image } from 'astro:assets';
import { article } from '@/lib/schema';
import { SITE } from '@/lib/site';
import { getEntry } from 'astro:content';
import inventoryImg from '@/assets/gallery/mark-inventory/tolkien-rare-books-inventory.jpg';

const PATH = '/sell-and-source';

const page = (await getEntry('pageContent', 'sell-and-source'))!;
const t = page.data.text as Record<string, string>;

const title = page.data.seo!.title!;
const description = page.data.seo!.description!;

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Sell & Source', url: PATH },
];

const schema = article({
  title,
  description,
  url: PATH,
  datePublished: '2026-07-02',
  dateModified: '2026-07-02',
});

const services = [
  { id: 'we-buy-tolkien-books', heading: t.buyHeading, body: t.buyBody },
  { id: 'consignment', heading: t.consignmentHeading, body: t.consignmentBody },
  { id: 'sourcing', heading: t.sourcingHeading, body: t.sourcingBody },
] as const;
---
<BaseLayout title={title} description={description} type="article" schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal class="mt-8 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
        {t.heroEyebrow}
      </p>
      <h1 class="mt-3 font-display text-4xl text-[var(--color-parchment)] sm:text-5xl">
        {t.heroH1}
      </h1>
    </Reveal>
  </Section>

  <Section tone="paper" space="lg">
    <ul class="grid gap-6 lg:grid-cols-3" role="list">
      {services.map((service, i) => (
        <li id={service.id}>
          <Reveal delay={i * 90}>
            <TrustCard heading={service.heading} body={service.body} />
          </Reveal>
        </li>
      ))}
    </ul>
  </Section>

  <Section tone="parchment" space="md">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <Reveal>
        <div class="rounded-[var(--radius)] border border-[var(--color-gold-600)]/30 bg-[var(--color-surface)] p-8 sm:p-10">
          <div class="flex flex-wrap gap-3">
            <Button href="/contact" variant="primary" size="lg">{t.ctaContact}</Button>
            <Button href={`mailto:${SITE.email}`} variant="ghost" size="lg">
              {SITE.email}
            </Button>
          </div>
        </div>
      </Reveal>
      <Reveal mode="fade" delay={120}>
        <figure class="overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/25">
          <Image
            src={inventoryImg}
            alt="Rare Tolkien first editions and collectable books in the Festival Art and Books inventory"
            widths={[400, 700, 1000]}
            sizes="(min-width: 1024px) 45vw, 100vw"
            class="w-full object-cover"
          />
        </figure>
      </Reveal>
    </div>
  </Section>
</BaseLayout>
