---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MarketplaceCTA from '@/components/MarketplaceCTA.astro';
import FaqList from '@/components/showcase/FaqList.astro';
import type { FaqItem } from '@/components/showcase/FaqList.astro';
import { Image } from 'astro:assets';
import { faqPage } from '@/lib/schema';
import { getEntry, getCollection } from 'astro:content';

const PATH = '/used-tolkien-books';

const page = (await getEntry('pageContent', 'used-tolkien-books'))!;
const t = page.data.text!;
const heroMontage = page.data.heroImage!;

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Used Books', url: PATH },
];

const faqs: FaqItem[] = (await getCollection('usedBooksFaqs'))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((item) => ({ question: item.data.question, answer: item.data.answer }));

const schema = faqPage(
  faqs.map((item) => ({
    question: item.question,
    answer: item.answer.join(' '),
  })),
);

const heroIntroRaw = t.heroIntro;
let introParagraphs: string[] = [];
if (typeof heroIntroRaw === 'string') {
  introParagraphs = heroIntroRaw.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
} else if (Array.isArray(heroIntroRaw) && heroIntroRaw.every((p) => typeof p === 'string')) {
  introParagraphs = heroIntroRaw;
}

/** Last paragraph bridges into the Q&A; earlier paragraphs are the background essay. */
const faqLead = introParagraphs.length > 1 ? introParagraphs.at(-1) : undefined;
const introBody = introParagraphs.length > 1 ? introParagraphs.slice(0, -1) : introParagraphs;
---
<BaseLayout
  title={page.data.seo!.title!}
  description={page.data.seo!.description!}
  schema={schema}
>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal class="mt-8 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
        {t.heroEyebrow}
      </p>
      <h1 id="used-tolkien-books-qa" class="mt-3 font-display text-4xl text-[var(--color-parchment)] sm:text-5xl">
        {t.heroH1}
      </h1>
    </Reveal>
  </Section>

  <Section tone="paper" width="wide" space="md">
    <Reveal as="figure">
      <Image
        src={heroMontage}
        alt={page.data.heroImageAlt as string}
        widths={[600, 900, 1200]}
        sizes="(min-width: 768px) 56rem, 100vw"
        class="w-full rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 object-cover"
      />
    </Reveal>
  </Section>

  {introBody.length > 0 && (
    <Section tone="parchment" width="wide" space="md">
      <Reveal as="div" class="prose-paper mx-auto space-y-5">
        {introBody.map((paragraph) => (
          <p class="font-text text-lg leading-relaxed text-[var(--color-text)]">{paragraph}</p>
        ))}
      </Reveal>
    </Section>
  )}

  <Section tone="paper" width="wide" id="faq" space="lg">
    {faqLead && (
      <Reveal class="prose-paper mx-auto mb-10">
        <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
          Frequently asked questions
        </p>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">{faqLead}</p>
      </Reveal>
    )}
    <FaqList items={faqs} collapsible />
  </Section>

  <Section tone="parchment" width="wide" space="md">
    <Reveal class="prose-paper mx-auto">
      <p class="font-text text-lg leading-relaxed text-[var(--color-text)]">
        <Fragment set:html={t.closingParagraph} />
      </p>
    </Reveal>
  </Section>

  <Section tone="surface">
    <MarketplaceCTA heading={t.marketplaceCtaHeading as string} tone="paper" />
  </Section>
</BaseLayout>
