---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Button from '@/components/Button.astro';
import Reveal from '@/components/Reveal.astro';
import { collectionPage } from '@/lib/schema';
import { JOURNAL } from '@/lib/site';
import issue1Cover from '@/assets/journal/festival-art-and-books-journal-issue-1-cover.jpg';

const entries = (await getCollection('journal', ({ data }) => !data.draft)).sort(
  (a: CollectionEntry<'journal'>, b: CollectionEntry<'journal'>) =>
    b.data.datePublished.getTime() - a.data.datePublished.getTime(),
);

const issue1 = JOURNAL.issue1;

const title = 'THE JOURNAL';
const description =
  'Enjoy previous editions of Festival Art and Books Journal, the online Tolkien magazine first published in 2009 by Mark Faith and Festival Art and Books.';

const schema = collectionPage({
  name: title,
  description,
  url: '/journal',
  items: [
    { name: issue1.title, url: issue1.pdf },
    ...entries.map((e) => ({ name: e.data.title, url: `/journal/${e.id}` })),
  ],
});
---
<BaseLayout title={`${title} | Festival Art & Books`} description={description} schema={schema}>
  <Section tone="midnight" space="lg">
    <Breadcrumbs
      class="!text-[var(--color-parchment)]/70"
      trail={[
        { name: 'Home', url: '/' },
        { name: 'Journal', url: '/journal' },
      ]}
    />
    <Reveal as="header" class="mt-8 max-w-[var(--content-max)]">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
        The Journal
      </p>
      <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl">
        {title}
      </h1>
      <p class="mt-6 text-xl text-[var(--color-parchment)]/80">
        Enjoy previous editions of Festival Art and Books Journal, the online Tolkien magazine
        first published in 2009 by Mark Faith and Festival Art and Books.
      </p>
    </Reveal>
  </Section>

  <Section space="lg">
    <Reveal
      as="article"
      class="grid max-w-4xl gap-8 overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] p-6 sm:grid-cols-[minmax(0,11rem)_1fr] sm:p-8"
    >
      <figure class="overflow-hidden rounded-sm border border-[var(--color-gold-600)]/20">
        <Image
          src={issue1Cover}
          alt="Festival Art and Books Journal Issue 1 (2009) — cover"
          widths={[176, 352]}
          sizes="(min-width: 640px) 11rem, 100vw"
          class="h-full w-full object-cover"
        />
      </figure>
      <div>
        <p class="font-ui text-xs uppercase tracking-[0.18em] text-[var(--color-gold-600)]">
          Archive · {issue1.published}
        </p>
        <h2 class="mt-2 font-display text-2xl text-[var(--color-midnight-900)] sm:text-3xl">
          Journal Issue 1
        </h2>
        <p class="mt-4 font-text text-lg leading-relaxed text-[var(--color-text)]">
          {issue1.description}
        </p>
        <p class="mt-3 font-ui text-sm text-[var(--color-muted)]">
          PDF · {issue1.pages} pages
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={issue1.pdf} variant="primary" size="lg" download>
            Download Issue 1 (PDF)
          </Button>
          <Button href={issue1.pdf} variant="ghost" size="lg" target="_blank" rel="noopener">
            View in browser
          </Button>
        </div>
      </div>
    </Reveal>

    {entries.length > 0 && (
      <ul class="mt-12 grid gap-8 sm:grid-cols-2">
        {entries.map((entry, i) => (
          <Reveal as="li" delay={i * 80}>
            <a
              href={`/journal/${entry.id}`}
              class="group flex h-full flex-col overflow-hidden rounded-sm border border-[var(--color-gold-600)]/20 bg-[var(--color-surface)] transition-colors"
            >
              <div class="flex flex-1 flex-col p-6">
                <p class="font-ui text-xs uppercase tracking-[0.18em] text-[var(--color-gold-600)]">
                  <time datetime={entry.data.datePublished.toISOString()}>
                    {new Intl.DateTimeFormat('en-GB', {
                      day: 'numeric',
                      month: 'long',
                      year: 'numeric',
                    }).format(entry.data.datePublished)}
                  </time>
                </p>
                <h2 class="mt-2 font-display text-2xl text-[var(--color-midnight-900)] group-hover:text-[var(--color-oxblood-600)]">
                  {entry.data.title}
                </h2>
                <p class="mt-3 flex-1 text-[var(--color-muted)]">{entry.data.description}</p>
                <span class="mt-4 font-ui text-sm text-[var(--color-oxblood-600)]">
                  Read the essay →
                </span>
              </div>
            </a>
          </Reveal>
        ))}
      </ul>
    )}
  </Section>
</BaseLayout>
