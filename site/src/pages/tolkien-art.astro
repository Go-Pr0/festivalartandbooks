---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MarketplaceCTA from '@/components/MarketplaceCTA.astro';
import ArtistCard from '@/components/showcase/ArtistCard.astro';
import type { Artist } from '@/components/showcase/ArtistCard.astro';
import { collectionPage } from '@/lib/schema';

import joeGilronan from '@/assets/showcase/artist-joe-gilronan-tolkien-artwork.jpg';
import rainerKalwitz from '@/assets/showcase/artist-rainer-kalwitz-tolkien-artwork.jpg';
import ruthLacon from '@/assets/showcase/artist-ruth-lacon-tolkien-artwork.jpg';
import rogerDean from '@/assets/showcase/artist-roger-dean-fantasy-artwork.jpg';
import michaelFishel from '@/assets/showcase/artist-michael-fishel-fantasy-artwork.jpg';
import tedNasmith from '@/assets/showcase/artist-ted-nasmith-tolkien-artwork.jpg';
import garyChalk from '@/assets/showcase/artist-gary-chalk-fantasy-artwork.jpg';
import timKirk from '@/assets/showcase/artist-tim-kirk-tolkien-artwork.jpg';
import rodneyMatthews from '@/assets/showcase/artist-rodney-matthews-fantasy-artwork.jpg';

const PATH = '/tolkien-art';

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Tolkien-Inspired Art', url: PATH },
];

const artists: Artist[] = [
  {
    name: 'Joe Gilronan',
    src: joeGilronan,
    alt: 'Tolkien-inspired landscape painting by artist Joe Gilronan',
    bio: [
      'A full-time professional artist from Chester, England, with a Fine Arts degree from Liverpool University. He works in oils, acrylic and clay.',
      'His love of Tolkien began as a child hearing The Hobbit read on Jackanory; landscapes from Snowdonia, the Cheshire plains and Andalucía feed his Middle-earth work.',
    ],
  },
  {
    name: 'Rainer Kalwitz',
    src: rainerKalwitz,
    alt: 'Fantasy artwork by Tolkien-inspired artist Rainer Kalwitz',
    bio: [
      'Based in Recklinghausen, Germany, Kalwitz has worked with major rock and metal labels including Century Media, Metal Blade, EMI and Roadrunner.',
      'He combines detailed brushwork with airbrush, built on intense photographic and sketch studies. Some of his images are among the best-selling poster prints in Europe.',
    ],
  },
  {
    name: 'Ruth Lacon',
    src: ruthLacon,
    alt: 'Tolkien-inspired illustration by artist Ruth Lacon',
    bio: [
      'A Tolkien enthusiast since her Edinburgh childhood, Ruth read The Silmarillion at twelve and joined the Tolkien Society in 1986. She holds degrees in Zoology and Design (Illustration).',
      'Her Tolkien-inspired work appears in her book The Art of Ruth Lacon, alongside scholarly papers on the author.',
    ],
  },
  {
    name: 'Roger Dean',
    src: rogerDean,
    alt: 'Fantasy landscape artwork by Roger Dean',
    bio: [
      'An internationally recognised artist and designer whose visionary images created a new genre, selling over sixty million copies worldwide.',
      'Best known for iconic 1970s and 80s album covers for the band Yes; a Royal College of Art graduate whose Sea Urchin Chair entered the V&A’s permanent collection.',
    ],
  },
  {
    name: 'Michael Fishel',
    src: michaelFishel,
    alt: 'Fantasy poster artwork by Michael Fishel',
    bio: [
      'Born in 1950, Fishel trained at the John Heron Institute of Art in Indiana and was published as full-colour posters by London’s Big “O” Poster Co. from 1977, alongside Roger Dean and Rodney Matthews.',
      'He went on to illustrate Dungeons & Dragons books and cover art for H.P. Lovecraft and Richard Adams; he now works in digital media in Austin, Texas.',
    ],
  },
  {
    name: 'Ted Nasmith',
    src: tedNasmith,
    alt: 'Tolkien illustration by Canadian artist Ted Nasmith',
    bio: [
      'A Canadian illustrator best known for his work on The Hobbit, The Lord of the Rings and The Silmarillion, whose luminist style appeared in Tolkien calendars from 1987.',
      'He illustrated the first illustrated edition of The Silmarillion (1998) and was invited to join John Howe and Alan Lee on conceptual art for Peter Jackson’s film trilogy.',
    ],
  },
  {
    name: 'Gary Chalk',
    src: garyChalk,
    alt: 'Fantasy illustration by artist Gary Chalk',
    bio: [
      'A prolific illustrator of children’s books and fantasy games, known for his black-and-white work on the Redwall and Lone Wolf series.',
      'He contributed to many of Games Workshop’s most popular board games and Warhammer publications and now lives in France.',
    ],
  },
  {
    name: 'Tim Kirk',
    src: timKirk,
    alt: 'Tolkien-inspired painting by artist Tim Kirk',
    bio: [
      'A five-time Hugo Award winner whose Lord of the Rings paintings appeared in the 1975 Tolkien Calendar published by Ballantine Books.',
      'He spent 22 years as a Disney Imagineer, contributing to Epcot, Tokyo DisneySea and more, before co-founding Kirk Design Inc.',
    ],
  },
  {
    name: 'Rodney Matthews',
    src: rodneyMatthews,
    alt: 'Fantasy artwork by artist Rodney Matthews',
    bio: [
      'Described by John Cleese as “among the greatest artists that have ever lived”, Matthews has illustrated Tolkien, C.S. Lewis, Lewis Carroll and many album covers.',
      'Born in Somerset and long settled in North Wales, his originals have shown at the Chris Beetles Gallery in London and in galleries from Switzerland to Machynlleth.',
      // TODO: Mark to supply a replacement for the missing "Rodney-Matthews-pics.jpg"
      // artwork image (the original returns HTTP 404 on the old site); using the
      // available portrait/artwork file in the meantime.
    ],
  },
];

const schema = collectionPage({
  name: 'Tolkien-Inspired Art',
  description:
    'Tolkien and Middle-earth inspired art handled by Festival Art and Books: original ' +
    'pre-2000 fantasy interpretations, rare promotional posters and officially commissioned work.',
  url: PATH,
  items: artists.map((artist) => ({ name: artist.name, url: PATH })),
});
---
<BaseLayout
  title="Tolkien-Inspired Art & Fantasy Artists | Festival Art & Books"
  description="Tolkien and Middle-earth inspired art: rare early promotional posters, original book illustration and the pre-2000 fantasy artists Festival Art and Books has represented."
  schema={schema}
>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal class="mt-8 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
        Middle-earth in paint
      </p>
      <h1 class="mt-3 font-display text-4xl text-[var(--color-parchment)] sm:text-5xl">
        Tolkien-Inspired Art
      </h1>
      <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/85">
        We focus on Tolkien and Middle-earth inspired art: originals, prints, and
        extremely rare promotional posters for the book releases, book illustrations and
        officially commissioned Middle-earth maps and artwork, now highly collectible.
      </p>
    </Reveal>
  </Section>

  <Section tone="paper" width="prose">
    <Reveal>
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        The art we handle today
      </h2>
      <div class="mt-6 space-y-5 font-text text-lg leading-relaxed text-[var(--color-text)]">
        <p>
          At our peak in 2015 we represented thirteen Tolkien-inspired artists. We have
          since phased out fantasy art to focus on book dealing, and because the rise of
          digital art, and the lasting influence of the films on new interpretations of
          Middle-earth, have not been kind to originality. We now deal only in art and
          posters tied to the early promotion of the books, or original art used in the
          books themselves, which is now extremely rare and valuable.
        </p>
        <p>
          By the late 1960s The Lord of the Rings had become a worldwide phenomenon,
          especially among American university students. Tolkien illustrated The Hobbit
          himself, but The Lord of the Rings carried illustration only on its dust
          jackets, which opened the door to official and unofficial Tolkien-inspired
          fantasy art. The early copyright holders were not vigilant, so many prints and
          posters appeared, amateur and professional.
        </p>
        <p>
          What we find most interesting is how artists imagined Middle-earth and its
          characters before the Peter Jackson films. Some felt it was not earth at all
          but another planet; most kept to a medieval or renaissance world with a
          fantastical flair. The debate continues: did the Balrog have wings? Since the
          early-2000s films, Alan Lee and John Howe have dominated our perception of
          Tolkien art. We collect and sell the earlier, pre-2000 interpretations, and
          occasionally the newer ones too.
        </p>
      </div>
    </Reveal>
  </Section>

  <Section tone="parchment">
    <Reveal>
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        Artists we have represented
      </h2>
      <p class="mt-3 max-w-2xl font-text text-lg text-[var(--color-muted)]">
        For a complete listing of available Tolkien-inspired fantasy art, email Mark at
        <a
          href="mailto:MarkFaith@festivalartandbooks.com"
          class="text-[var(--color-midnight-900)] underline decoration-[var(--color-gold-600)]/50 underline-offset-4 hover:text-[var(--color-oxblood-600)]"
        >MarkFaith@festivalartandbooks.com</a>.
      </p>
    </Reveal>
    <ul class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {artists.map((artist, i) => (
        <Reveal as="li" mode="up" delay={i * 70} class="h-full">
          <ArtistCard artist={artist} class="h-full" />
        </Reveal>
      ))}
    </ul>
  </Section>

  <Section tone="surface">
    <MarketplaceCTA heading="Enquire about Tolkien art & posters" tone="paper" />
  </Section>
</BaseLayout>
