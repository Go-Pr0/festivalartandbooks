---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Reveal from '@/components/Reveal.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MarketplaceCTA from '@/components/MarketplaceCTA.astro';
import ArtistCard from '@/components/showcase/ArtistCard.astro';
import type { Artist } from '@/components/showcase/ArtistCard.astro';
import { collectionPage } from '@/lib/schema';
import { getEntry, getCollection } from 'astro:content';

const page = (await getEntry('pageContent', 'tolkien-art'))!;
const t = page.data.text!;

const PATH = '/tolkien-art';

const trail = [
  { name: 'Home', url: '/' },
  { name: 'Tolkien-Inspired Art', url: PATH },
];

// TODO: Mark to supply a replacement for the missing "Rodney-Matthews-pics.jpg"
// artwork image (the original returns HTTP 404 on the old site); using the
// available portrait/artwork file in the meantime.
const artists: Artist[] = (await getCollection('artists'))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((a) => ({
    name: a.data.name,
    src: a.data.image,
    alt: a.data.alt,
    bio: a.data.bio,
  }));

const schema = collectionPage({
  name: 'Tolkien-Inspired Art',
  description:
    'Tolkien and Middle-earth inspired art handled by Festival Art and Books: original ' +
    'pre-2000 fantasy interpretations, rare promotional posters and officially commissioned work.',
  url: PATH,
  items: artists.map((artist) => ({ name: artist.name, url: PATH })),
});
---
<BaseLayout
  title={page.data.seo!.title!}
  description={page.data.seo!.description!}
  schema={schema}
>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <Reveal class="mt-8 max-w-3xl">
      <p class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-300)]">
        {t.heroEyebrow}
      </p>
      <h1 class="mt-3 font-display text-4xl text-[var(--color-parchment)] sm:text-5xl">
        {t.heroH1}
      </h1>
      <p class="mt-6 font-text text-xl leading-relaxed text-[var(--color-parchment)]/85">
        {t.heroIntro}
      </p>
    </Reveal>
  </Section>

  <Section tone="paper" width="prose">
    <Reveal>
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        {t.artHeading}
      </h2>
      <div class="mt-6 space-y-5 font-text text-lg leading-relaxed text-[var(--color-text)]">
        <p>
          {t.artP1}
        </p>
        <p>
          {t.artP2}
        </p>
        <p>
          {t.artP3}
        </p>
      </div>
    </Reveal>
  </Section>

  <Section tone="parchment">
    <Reveal>
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">
        {t.artistsHeading}
      </h2>
      <p class="mt-3 max-w-2xl font-text text-lg text-[var(--color-muted)]">
        <Fragment set:html={t.artistsIntro} />
      </p>
    </Reveal>
    <ul class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {artists.map((artist, i) => (
        <Reveal as="li" mode="up" delay={i * 70} class="h-full">
          <ArtistCard artist={artist} class="h-full" />
        </Reveal>
      ))}
    </ul>
  </Section>

  <Section tone="surface">
    <MarketplaceCTA heading={t.marketplaceCTAHeading as string} tone="paper" />
  </Section>
</BaseLayout>
