---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Figure from '@/components/story/Figure.astro';
import { collectionPage } from '@/lib/schema';
import { getEntry, getCollection } from 'astro:content';

interface MediaMention {
  outlet: string;
  headline: string;
  url: string;
}

const page = (await getEntry('pageContent', 'news-media'))!;
const t = page.data.text!;
const title = page.data.seo!.title!;
const description = page.data.seo!.description!;

const figure = (key: string) => page.data.figures!.find((f) => f.key === key)!;
const pressFigure = figure('press');

const trail = [
  { name: 'Home', url: '/' },
  { name: 'News & Media', url: '/news-media' },
];

const mentions: MediaMention[] = (await getCollection('mediaMentions'))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((m) => ({ outlet: m.data.outlet, headline: m.data.headline, url: m.data.url }));

const schema = collectionPage({
  name: 'News & Media — Festival Art & Books',
  description,
  url: '/news-media',
  items: mentions.map((m) => ({ name: `${m.outlet}: ${m.headline}`, url: m.url })),
});
---
<BaseLayout title={title} description={description} schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <div class="mt-10 grid items-center gap-12 lg:grid-cols-[1.4fr_1fr]">
      <Reveal as="div" mode="up">
        <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">{t.heroEyebrow}</p>
        <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
          {t.heroH1}
        </h1>
        <p class="mt-6 max-w-prose font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
          {t.heroIntro}
        </p>
      </Reveal>
      <Figure
        src={pressFigure.src}
        alt={pressFigure.alt}
        caption={pressFigure.caption}
        frame={pressFigure.frame as 'default' | 'portrait'}
        delay={pressFigure.delay}
        sizes={pressFigure.sizes}
      />
    </div>
  </Section>

  <Section space="lg">
    <Reveal as="div" mode="up">
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">{t.pressHeading}</h2>
      <p class="mt-3 max-w-prose font-text text-lg text-[var(--color-muted)]">
        {t.pressIntro}
      </p>
    </Reveal>
    <ul class="mt-10 grid gap-4 sm:grid-cols-2">
      {mentions.map((mention, i) => (
        <Reveal as="li" mode="up" delay={(i % 2) * 70}>
          <a
            href={mention.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-full flex-col rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-gold-500)]"
          >
            <span class="font-ui text-xs uppercase tracking-[0.18em] text-[var(--color-gold-600)]">{mention.outlet}</span>
            <span class="mt-1 font-display text-xl leading-snug text-[var(--color-midnight-900)]">{mention.headline}</span>
          </a>
        </Reveal>
      ))}
    </ul>
    {/* TODO: Mark to confirm exact outlet names / verify each link is still live; a few
        sources were community blogs or wikis rather than named press outlets. */}
  </Section>

  <Section tone="parchment" space="md">
    <Reveal as="div" mode="up" class="max-w-2xl">
      <h2 class="font-display text-2xl text-[var(--color-midnight-900)] sm:text-3xl">{t.moreCoverageHeading}</h2>
      <p class="mt-3 font-text text-lg leading-relaxed text-[var(--color-text)]">
        <Fragment set:html={t.moreCoverageP} />
      </p>
      {/* TODO: Mark to confirm Nazareth DVD release/title detail and any press-contact note. */}
    </Reveal>
  </Section>
</BaseLayout>
