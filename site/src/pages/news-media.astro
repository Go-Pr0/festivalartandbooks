---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Reveal from '@/components/Reveal.astro';
import Figure from '@/components/story/Figure.astro';
import { collectionPage } from '@/lib/schema';

import pressImage from '@/assets/story/mark-faith-press-media-hobbit-first-edition.jpg';

interface MediaMention {
  outlet: string;
  headline: string;
  url: string;
}

const title = 'News & Media: Press Coverage of Mark Faith | Festival Art & Books';
const description =
  'Two decades of press and media coverage of Mark Faith and Festival Art and Books: the BBC, ' +
  'WalesOnline, CBS News, Tolkien Library, AbeBooks and more on rare Tolkien books.';

const trail = [
  { name: 'Home', url: '/' },
  { name: 'News & Media', url: '/news-media' },
];

// Outlets named verbatim from source links; headline summaries describe each link.
const mentions: MediaMention[] = [
  {
    outlet: 'BBC News (Mid Wales)',
    headline: 'Tolkien festival held in mid-Wales',
    url: 'https://www.bbc.co.uk/news/uk-wales-mid-wales-10954446',
  },
  {
    outlet: 'WalesOnline',
    headline: 'Tolkien festival held in mid-Wales',
    url: 'https://www.walesonline.co.uk/news/wales-news/tolkien-festival-held-middle-wales-2079036',
  },
  {
    outlet: 'BBC Wales (blog)',
    headline: 'Festival in the Shire coverage',
    url: 'https://www.bbc.co.uk/blogs/wales/entries/d5064482-14e6-3525-ab42-dea2dea7efef',
  },
  {
    outlet: 'CBS News',
    headline: 'Priciest Tolkien book in the world sold',
    url: 'https://www.cbsnews.com/news/priciest-tolkien-book-in-the-world-sold',
  },
  {
    outlet: 'BBC News (Entertainment & Arts)',
    headline: 'The Hobbit first edition fetches £137,000 at auction',
    url: 'https://www.bbc.co.uk/news/entertainment-arts-33013144',
  },
  {
    outlet: 'Tolkien Library',
    headline: 'Interview: Festival in the Shire',
    url: 'https://tolkienlibrary.com/press/940-interview-festival-in-the-shire.php',
  },
  {
    outlet: 'Tolkien Library',
    headline: 'The most expensive Tolkien book in the world',
    url: 'https://tolkienlibrary.com/press/856-most-expensive-tolkien-book-in-the-world.php',
  },
  {
    outlet: 'Tolkien Library',
    headline: 'The Hobbit association copies',
    url: 'https://tolkienlibrary.com/press/987-the-hobbit-association-copies.php',
  },
  {
    outlet: 'AbeBooks',
    headline: 'Collecting J.R.R. Tolkien books',
    url: 'https://www.abebooks.com/books/collecting-jrr-tolkien-books',
  },
  {
    outlet: 'GamesRadar',
    headline: 'Festival in the Shire',
    url: 'https://www.gamesradar.com/festival-in-the-shire',
  },
  {
    outlet: 'Middle-earth News',
    headline: 'Festival in the Shire is returning to Scotland',
    url: 'https://middleearthnews.com/2013/11/05/festival-in-the-shire-is-returning-to-scotland/',
  },
  {
    outlet: 'JRRTolkien.it',
    headline: 'Torna in Galles il Festival in the Shire',
    url: 'https://www.jrrtolkien.it/2011/08/17/torna-in-galles-il-festival-in-the-shire/',
  },
  {
    outlet: 'Dimitra Fimi',
    headline: 'Festival in the Shire (October 2009)',
    url: 'https://dimitrafimi.com/2009/10',
  },
];

const schema = collectionPage({
  name: 'News & Media — Festival Art & Books',
  description,
  url: '/news-media',
  items: mentions.map((m) => ({ name: `${m.outlet}: ${m.headline}`, url: m.url })),
});
---
<BaseLayout title={title} description={description} schema={schema}>
  <Section tone="midnight" space="md">
    <Breadcrumbs trail={trail} class="text-[var(--color-parchment)]/70" />
    <div class="mt-10 grid items-center gap-12 lg:grid-cols-[1.4fr_1fr]">
      <Reveal as="div" mode="up">
        <p class="font-ui text-xs uppercase tracking-[0.25em] text-[var(--color-gold-300)]">As seen in</p>
        <h1 class="mt-3 font-display text-4xl leading-tight text-[var(--color-parchment)] sm:text-5xl lg:text-6xl">
          News &amp; media
        </h1>
        <p class="mt-6 max-w-prose font-text text-xl leading-relaxed text-[var(--color-parchment)]/90">
          Over the last 20 years Mark Faith and Festival Art and Books have been covered across the
          press and Tolkien community, from the BBC and WalesOnline to CBS News, the Tolkien Library
          and AbeBooks. Below is a sample of the official mentions we endorse; there have been many
          more besides.
        </p>
      </Reveal>
      <Figure
        src={pressImage}
        alt="An autographed headshot above a handwritten thank-you card sent to Mark Faith for the use of a first-edition Hobbit"
        caption="Press and production thanks for the use of Mark’s first-edition Hobbit."
        frame="portrait"
        delay={120}
        sizes="(min-width: 1024px) 22rem, 80vw"
      />
    </div>
  </Section>

  <Section space="lg">
    <Reveal as="div" mode="up">
      <h2 class="font-display text-3xl text-[var(--color-midnight-900)] sm:text-4xl">Press &amp; media coverage</h2>
      <p class="mt-3 max-w-prose font-text text-lg text-[var(--color-muted)]">
        A selection of official media links from across two decades of Tolkien dealing and events.
      </p>
    </Reveal>
    <ul class="mt-10 grid gap-4 sm:grid-cols-2">
      {mentions.map((mention, i) => (
        <Reveal as="li" mode="up" delay={(i % 2) * 70}>
          <a
            href={mention.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-full flex-col rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-gold-500)]"
          >
            <span class="font-ui text-xs uppercase tracking-[0.18em] text-[var(--color-gold-600)]">{mention.outlet}</span>
            <span class="mt-1 font-display text-xl leading-snug text-[var(--color-midnight-900)]">{mention.headline}</span>
          </a>
        </Reveal>
      ))}
    </ul>
    {/* TODO: Mark to confirm exact outlet names / verify each link is still live; a few
        sources were community blogs or wikis rather than named press outlets. */}
  </Section>

  <Section tone="parchment" space="md">
    <Reveal as="div" mode="up" class="max-w-2xl">
      <h2 class="font-display text-2xl text-[var(--color-midnight-900)] sm:text-3xl">More coverage</h2>
      <p class="mt-3 font-text text-lg leading-relaxed text-[var(--color-text)]">
        Mark and artist Rodney Matthews were also interviewed for a feature documentary on the
        Nazareth DVD <em>No Means of Escape</em>, filmed live at Metropolis Studios. For more on
        Mark’s on-screen work, see his <a class="underline decoration-[var(--color-gold-500)]/60 underline-offset-4" href="/tv-appearances">TV appearances</a>.
      </p>
      {/* TODO: Mark to confirm Nazareth DVD release/title detail and any press-contact note. */}
    </Reveal>
  </Section>
</BaseLayout>
