---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Reveal from '@/components/Reveal.astro';

interface Props {
  currentId: string;
}

const { currentId } = Astro.props;

const allGuides = (await getCollection('guides', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime(),
);

const current = allGuides.find((g) => g.id === currentId);
const currentCluster = current?.data.cluster;

const others = allGuides.filter((g) => g.id !== currentId);

const sameCluster = currentCluster
  ? others.filter((g) => g.data.cluster === currentCluster)
  : [];

const otherPillars = others.filter(
  (g) => g.data.pillar && !sameCluster.some((s) => s.id === g.id),
);

const remainder = others.filter(
  (g) =>
    !sameCluster.some((s) => s.id === g.id) && !otherPillars.some((p) => p.id === g.id),
);

const related: CollectionEntry<'guides'>[] = [];
const seen = new Set<string>();

for (const guide of [...sameCluster, ...otherPillars, ...remainder]) {
  if (related.length >= 3) break;
  if (seen.has(guide.id)) continue;
  seen.add(guide.id);
  related.push(guide);
}
---
{related.length > 0 && (
  <Reveal class="mx-auto mt-16 max-w-[var(--content-max)] border-t border-[var(--color-gold-600)]/20 pt-8">
    <h2 class="font-display text-3xl text-[var(--color-midnight-900)]">Related guides</h2>
    <ul class="mt-8 grid gap-4 sm:grid-cols-3">
      {related.map((guide) => (
        <li>
          <a
            href={`/guides/${guide.id}`}
            class="group flex h-full flex-col rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-gold-500)]"
          >
            {guide.data.pillar && (
              <span class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-600)]">
                Cornerstone Guide
              </span>
            )}
            <span class="mt-1 font-display text-lg text-[var(--color-midnight-900)] group-hover:text-[var(--color-oxblood-600)]">
              {guide.data.title}
            </span>
            <span class="mt-2 flex-1 text-sm text-[var(--color-muted)]">{guide.data.description}</span>
            <span class="mt-3 font-ui text-sm text-[var(--color-oxblood-600)]">Read guide →</span>
          </a>
        </li>
      ))}
    </ul>
  </Reveal>
)}
