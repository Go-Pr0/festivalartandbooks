---
/**
 * Responsive image gallery for showcase pages. Each item is an optimised Astro
 * <Image> with precise alt text and an optional caption. Items reveal on scroll
 * with a staggered delay so the gallery assembles gracefully.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Reveal from '@/components/Reveal.astro';

export interface GalleryItem {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  category?: string;
}

interface Props {
  items: GalleryItem[];
  /** Grid columns at the large breakpoint. */
  columns?: 2 | 3 | 4;
  class?: string;
  /** When set, each item is tagged for client-side category filtering. */
  filterable?: boolean;
}

const { items, columns = 3, class: className = '', filterable = false } = Astro.props;

const colClass: Record<NonNullable<Props['columns']>, string> = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
};
---
<ul
  class:list={['grid grid-cols-1 gap-6', colClass[columns], className, filterable && 'gallery-grid']}
  role="list"
  data-gallery={filterable ? '' : undefined}
>
  {items.map((item, i) =>
    filterable ? (
      <li
        data-category={item.category ?? ''}
        data-reveal
        data-reveal-delay={String(i * 80)}
        class="group"
      >
        <figure
          class="overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] shadow-sm"
        >
          <div class="overflow-hidden">
            <Image
              src={item.src}
              alt={item.alt}
              widths={[400, 700, 1000]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              class="aspect-[4/3] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
            />
          </div>
          {item.caption && (
            <figcaption class="px-4 py-3 font-ui text-sm text-[var(--color-muted)]">
              {item.caption}
            </figcaption>
          )}
        </figure>
      </li>
    ) : (
      <Reveal as="li" mode="up" delay={i * 80} class="group">
        <figure
          class="overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] shadow-sm"
        >
          <div class="overflow-hidden">
            <Image
              src={item.src}
              alt={item.alt}
              widths={[400, 700, 1000]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              class="aspect-[4/3] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
            />
          </div>
          {item.caption && (
            <figcaption class="px-4 py-3 font-ui text-sm text-[var(--color-muted)]">
              {item.caption}
            </figcaption>
          )}
        </figure>
      </Reveal>
    ),
  )}
</ul>
