---
/**
 * A visual teaser card for "what Mark deals in": an optimised book image above a short
 * heading, blurb and a link to the relevant collection or guides page.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** Imported image asset (astro:assets ImageMetadata). */
  image: ImageMetadata;
  /** Precise alt text describing the edition/subject shown. */
  alt: string;
  /** Card heading. */
  heading: string;
  /** Short supporting blurb. */
  body: string;
  /** Internal link target. */
  href: string;
  /** Link label. */
  cta: string;
}

const { image, alt, heading, body, href, cta } = Astro.props;
---
<a
  href={href}
  class="group flex h-full flex-col overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] no-underline transition-shadow duration-200 hover:shadow-lg"
>
  <div class="aspect-[4/3] overflow-hidden">
    <Image
      src={image}
      alt={alt}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
      widths={[480, 768]}
      sizes="(min-width: 768px) 33vw, 100vw"
    />
  </div>
  <div class="flex flex-1 flex-col p-7">
    <h3 class="font-display text-2xl text-[var(--color-midnight-900)]">{heading}</h3>
    <p class="mt-3 flex-1 font-text text-lg leading-relaxed text-[var(--color-muted)]">{body}</p>
    <span class="mt-5 font-ui text-sm uppercase tracking-[0.18em] text-[var(--color-gold-600)] group-hover:text-[var(--color-gold-500)]">
      {cta} &rarr;
    </span>
  </div>
</a>
