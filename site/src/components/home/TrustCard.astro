---
/**
 * A single "why buy from Mark" trust point: a short heading and a line of supporting copy,
 * set as an elegant bordered card. Rendered inside a Reveal grid on the homepage.
 */
interface Props {
  /** Short trust heading, e.g. "In stock, not brokered". */
  heading: string;
  /** One or two sentences of supporting detail. */
  body: string;
}

const { heading, body } = Astro.props;
---
<div class="h-full rounded-[var(--radius)] border border-[var(--color-gold-600)]/30 bg-[var(--color-surface)] p-7">
  <h3 class="font-display text-2xl text-[var(--color-midnight-900)]">{heading}</h3>
  <p class="mt-3 font-text text-lg leading-relaxed text-[var(--color-muted)]">{body}</p>
</div>
