---
/**
 * Homepage hero. A full-bleed montage of Tolkien first-edition covers behind a midnight
 * gradient, the brand wordmark/title, a one-line authoritative positioning statement and
 * the two primary CTAs (browse the collection / read the guides). Text sits over a dark
 * overlay for legibility; a restrained entrance animation brings the copy in on load.
 */
import { Image } from 'astro:assets';
import Button from '@/components/Button.astro';
import { EXTERNAL, SITE } from '@/lib/site';
import heroImage from '@/assets/home/fab-dragon-poster-hero.jpg';

interface Props {
  /** Brand title shown as the hero wordmark. */
 title: string;
  /** Sub-line beneath the title (the speciality). */
 subtitle: string;
  /** One-line authoritative positioning statement. */
 positioning: string;
}

const { title, subtitle, positioning } = Astro.props;
---
<header class="relative isolate overflow-hidden bg-[var(--color-midnight-950)]" data-tone="midnight">
 <div class="absolute inset-0 -z-10 overflow-hidden">
 <Image
 src={heroImage}
 alt="Golden dragon in flight over Middle-earth, Festival Art and Books Tolkien rare books poster artwork"
 class="hero-bg-image h-[115%] w-full max-w-none object-cover"
 widths={[768, 1280, 1920]}
 sizes="100vw"
 loading="eager"
 fetchpriority="high"
 />
 </div>
 <div
 class="absolute inset-0 -z-10"
 style="background: linear-gradient(to right, rgb(13 20 48 / 0.82) 0%, rgb(13 20 48 / 0.44) 55%, rgb(13 20 48 / 0.14) 100%);"
 aria-hidden="true"
 ></div>
 <div
 class="absolute inset-0 -z-10"
 style="background: linear-gradient(to bottom, rgb(13 20 48 / 0.28) 0%, transparent 45%, rgb(13 20 48 / 0.72) 100%);"
 aria-hidden="true"
 ></div>

 <div class="mx-auto w-full max-w-[var(--page-max)] px-6 py-28 sm:px-8 sm:py-36 lg:py-44">
 <div class="max-w-3xl" data-reveal>
 <p class="font-ui text-xs uppercase tracking-[0.32em] text-[var(--color-gold-300)]">
 {SITE.dealerTagline}
 </p>
 <h1 class="mt-6 font-display text-5xl font-semibold leading-[1.05] text-[var(--color-parchment)] sm:text-6xl lg:text-7xl">
 {title}
 <span class="mt-2 block text-3xl font-normal italic text-[var(--color-gold-300)] sm:text-4xl">
 {subtitle}
 </span>
 </h1>
 <p class="mt-7 max-w-2xl font-text text-xl leading-relaxed text-[var(--color-parchment)]/90 sm:text-2xl">
 {positioning}
 </p>
 <div class="mt-10 flex flex-wrap gap-4">
 <Button href={EXTERNAL.ebay} variant="primary" size="lg">
 Browse the collection
 </Button>
 <Button href="/guides" variant="ghost" size="lg">
 Read the guides
 </Button>
 </div>
 </div>
 </div>
</header>

<style>
 .hero-bg-image {
 opacity: 0.62;
 object-position: 50% 30%;
 }

  /* Wide viewports crop heavily with object-cover — anchor to the image bottom
 so the dragon doesn't zoom into the middle of its body. */
 @media (min-width: 1024px) {
 .hero-bg-image {
 object-position: 50% 100%;
 }
 }
</style>
