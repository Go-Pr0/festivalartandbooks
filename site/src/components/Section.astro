---
/**
 * Vertical-rhythm section band with an optional surface tone. Wraps its children in a
 * Container by default so pages compose as a stack of <Section> blocks.
 */
import Container from '@/components/Container.astro';

type Tone = 'paper' | 'parchment' | 'surface' | 'midnight';
type Space = 'sm' | 'md' | 'lg';

interface Props {
  tone?: Tone;
  /** Vertical padding scale. */
  space?: Space;
  /** Set false to omit the inner Container (page handles its own width). */
  contained?: boolean;
  width?: 'page' | 'wide' | 'prose';
  as?: 'section' | 'div' | 'article' | 'footer' | 'header';
  /** Fragment-identifier id for deep-linking / AI extraction. */
  id?: string;
  class?: string;
}

const {
  tone = 'paper',
  space = 'lg',
  contained = true,
  width = 'page',
  as = 'section',
  id,
  class: className = '',
}: Props = Astro.props;

const Tag = as;

const tones: Record<Tone, string> = {
  paper: 'bg-[var(--color-bg)] text-[var(--color-text)]',
  parchment: 'bg-[var(--color-parchment-dim)] text-[var(--color-text)]',
  surface: 'bg-[var(--color-surface)] text-[var(--color-text)]',
  midnight: 'bg-[var(--color-midnight-900)] text-[var(--color-parchment)]',
};

const spacing: Record<Space, string> = {
  sm: 'py-10 sm:py-12',
  md: 'py-14 sm:py-20',
  lg: 'py-20 sm:py-28',
};
---
<Tag id={id} class:list={[tones[tone], spacing[space], className]} data-tone={tone}>
  {contained ? (
    <Container width={width}>
      <slot />
    </Container>
  ) : (
    <slot />
  )}
</Tag>
