---
/**
 * Site header: sticky, condenses on scroll, with the Wordmark, primary nav, and an
 * accessible Resources dropdown. Mobile uses a slide-down panel toggled by a hamburger.
 * Behaviour lives in the inline module script (keyboard + click-outside + view-transition safe).
 */
import Container from '@/components/Container.astro';
import Wordmark from '@/components/Wordmark.astro';
import { NAV } from '@/lib/site';
---
<header
  id="site-header"
  class="group/header sticky top-0 z-50 border-b border-[var(--color-gold-600)]/25 bg-[var(--color-bg)]/90 backdrop-blur transition-shadow duration-300 data-[scrolled]:shadow-[0_1px_24px_-12px_rgba(13,20,48,0.55)]"
>
  <Container>
    <div class="flex items-center justify-between gap-3 py-2.5 transition-[padding] duration-300 group-data-[scrolled]/header:py-2 xl:gap-6">
      <Wordmark compact class="min-w-0 max-w-[min(100%,14rem)] sm:max-w-none" />

      <!-- Desktop nav — xl+ so the bar fits without wrapping -->
      <nav class="hidden shrink-0 items-center gap-x-3 gap-y-1 xl:flex 2xl:gap-x-4" aria-label="Primary">
        {NAV.map((item) =>
          item.children ? (
            <div class="nav-dropdown relative">
              <button
                type="button"
                class="nav-dropdown__trigger flex items-center gap-1 whitespace-nowrap font-ui text-[0.8125rem] text-[var(--color-midnight-900)] hover:text-[var(--color-oxblood-600)] 2xl:text-sm"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="h-3 w-3 shrink-0 transition-transform duration-200" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 4.5 L6 8 L9.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
              </button>
              <div
                class="nav-dropdown__menu invisible absolute right-0 top-full min-w-56 translate-y-1 rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] py-2 opacity-0 shadow-[0_12px_40px_-12px_rgba(13,20,48,0.45)] transition-all duration-200"
                role="menu"
              >
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    role="menuitem"
                    class="block px-4 py-2 font-ui text-sm text-[var(--color-ink)] hover:bg-[var(--color-gold-500)]/10 hover:text-[var(--color-oxblood-600)]"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="whitespace-nowrap font-ui text-[0.8125rem] text-[var(--color-midnight-900)] hover:text-[var(--color-oxblood-600)] 2xl:text-sm"
            >
              {item.label}
            </a>
          ),
        )}
      </nav>

      <!-- Mobile toggle -->
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex shrink-0 items-center justify-center rounded-[var(--radius)] p-2 text-[var(--color-midnight-900)] xl:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </Container>

  <!-- Mobile menu -->
  <div id="mobile-menu" hidden class="border-t border-[var(--color-gold-600)]/20 bg-[var(--color-surface)] xl:hidden">
    <Container>
      <nav class="flex flex-col gap-1 py-4" aria-label="Mobile">
        {NAV.map((item) =>
          item.children ? (
            <details class="group">
              <summary class="flex cursor-pointer items-center justify-between py-2 font-ui text-base text-[var(--color-midnight-900)] marker:content-['']">
                {item.label}
                <svg class="h-4 w-4 transition-transform group-open:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 4.5 L6 8 L9.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
              </summary>
              <div class="ml-3 flex flex-col border-l border-[var(--color-gold-600)]/30 pl-3">
                {item.children.map((child) => (
                  <a href={child.href} class="py-2 font-ui text-sm text-[var(--color-ink)] hover:text-[var(--color-oxblood-600)]">
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a href={item.href} class="py-2 font-ui text-base text-[var(--color-midnight-900)] hover:text-[var(--color-oxblood-600)]">
              {item.label}
            </a>
          ),
        )}
      </nav>
    </Container>
  </div>
</header>

<script>
  import { initHeader } from '@/scripts/header';
  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
