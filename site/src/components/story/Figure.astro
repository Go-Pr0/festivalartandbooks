---
/**
 * Captioned, optimized image for the story pages. Wraps Astro's <Image> with a
 * brand-styled <figure>/<figcaption> and reveals on scroll. Pass an imported
 * image (ImageMetadata) plus precise alt text; caption is optional.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Reveal from '@/components/Reveal.astro';

interface Props {
  src: ImageMetadata;
  /** Precise, descriptive alt text (subject / context). Required for accessibility + SEO. */
  alt: string;
  /** Optional visible caption. */
  caption?: string;
  /** Layout width hint passed to <Image> for responsive sizing. */
  widths?: number[];
  sizes?: string;
  /** Stagger delay for the reveal animation, in ms. */
  delay?: number;
  /** Constrain to a portrait/tall montage frame. */
  frame?: 'default' | 'portrait';
  class?: string;
}

const {
  src,
  alt,
  caption,
  widths = [480, 800, 1200],
  sizes = '(min-width: 768px) 36rem, 100vw',
  delay,
  frame = 'default',
  class: className = '',
} = Astro.props;
---
<Reveal as="figure" mode="up" delay={delay} class={`group ${className}`}>
  <div class="overflow-hidden rounded-[var(--radius)] border border-[var(--color-gold-600)]/25 bg-[var(--color-surface)] shadow-sm">
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      class:list={[
        'h-auto w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.02]',
        frame === 'portrait' ? 'aspect-[3/4] object-cover' : '',
      ]}
    />
  </div>
  {caption && (
    <figcaption class="mt-3 font-ui text-sm italic text-[var(--color-muted)]">
      {caption}
    </figcaption>
  )}
</Reveal>
