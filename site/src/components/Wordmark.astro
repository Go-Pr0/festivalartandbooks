---
/**
 * Brand wordmark: dragon trademark logo + display-serif name and tagline.
 * Used in the Header and Footer. `compact` trims size for the sticky header bar.
 */
import DragonLogo from '@/components/DragonLogo.astro';
import { SITE } from '@/lib/site';

interface Props {
  /** Wrap in a link to home. Off when already used inside a heading. */
  href?: string;
  /** Light variant for dark (midnight) backgrounds. */
  tone?: 'dark' | 'light';
  /** Smaller logo + name for the header bar; tagline hidden until 2xl. */
  compact?: boolean;
  class?: string;
}

const { href = '/', tone = 'dark', compact = false, class: className = '' } = Astro.props;

const nameColor = tone === 'light' ? 'text-[var(--color-parchment)]' : 'text-[var(--color-midnight-900)]';
const taglineColor =
  tone === 'light'
    ? 'text-[var(--color-parchment)]/90'
    : 'text-[var(--color-gold-600)]';
const Tag = href ? 'a' : 'span';
---
<Tag
  href={href || undefined}
  class:list={['group inline-flex min-w-0 items-center gap-2 sm:gap-3', className]}
  aria-label={href ? `${SITE.name}, home` : undefined}
>
  <DragonLogo
    size={compact ? 'sm' : 'md'}
    class="shrink-0 transition-transform duration-500 group-hover:rotate-[18deg]"
  />
  <span class="flex min-w-0 flex-col leading-none">
    <span
      class:list={[
        'truncate font-display tracking-wide',
        compact ? 'text-lg xl:text-xl' : 'text-xl sm:text-2xl',
        nameColor,
      ]}
    >
      Festival Art &amp; Books
    </span>
    <span
      class:list={[
        'font-ui uppercase tracking-[0.28em]',
        compact ? 'hidden text-[0.55rem] 2xl:block' : 'text-[0.6rem]',
        taglineColor,
      ]}
    >
      {SITE.tagline}
    </span>
  </span>
</Tag>
