---
/**
 * Round dragon trademark logo — content-centred emblem served from /public.
 * The circle mask lives on a wrapper so the raster stays optically centred.
 */
interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  href?: string;
}

const { size = 'md', class: className = '', href } = Astro.props;

const sizes = { sm: 40, md: 52, lg: 76 } as const;
const px = sizes[size];
const src = '/images/fab-dragon-logo.png';
const Tag = href ? 'a' : 'span';
---
<Tag
  href={href}
  class:list={['inline-flex shrink-0', className]}
  aria-label={href ? 'Festival Art and Books, home' : undefined}
>
  <span
    class="block shrink-0 overflow-hidden rounded-full bg-white ring-1 ring-[var(--color-gold-600)]/20"
    style={`width: ${px}px; height: ${px}px;`}
  >
    <img
      src={src}
      alt="Festival Art and Books dragon trademark logo"
      width={px}
      height={px}
      class="block size-full object-cover object-center"
      loading="eager"
      decoding="async"
    />
  </span>
</Tag>
