---
/**
 * Site footer: wordmark + positioning line, contact, location (Aberdyfi, Wales),
 * marketplace links, condensed nav, and a tasteful gold rule. All links are real so
 * the footer doubles as a crawlable internal-link hub.
 */
import Container from '@/components/Container.astro';
import Wordmark from '@/components/Wordmark.astro';
import { NAV, EXTERNAL, SITE } from '@/lib/site';

const year = new Date().getFullYear();
// Flatten to real internal routes. Dropdown parents (e.g. Resources) are label-only
// groupings, not pages, so we keep their children but drop the parent itself.
const flatNav = NAV.flatMap((item) =>
  item.children ? item.children : [item],
).filter((item) => item.href.startsWith('/'));
---
<footer class="bg-[var(--color-midnight-950)] text-[var(--color-parchment)]">
  <!-- Gold rule -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-[var(--color-gold-500)]/70 to-transparent"></div>

  <Container>
    <div class="grid gap-12 py-16 md:grid-cols-[1.4fr_1fr_1fr]">
      <!-- Brand + positioning -->
      <div>
        <Wordmark tone="light" />
        <p class="mt-5 max-w-sm font-text text-[var(--color-parchment)]/75">
          Specialist dealer in rare and first-edition J.R.R. Tolkien books and
          Tolkien-inspired art, run by Mark Faith for over 25 years. We ship worldwide.
        </p>
        <address class="mt-5 not-italic font-ui text-sm text-[var(--color-parchment)]/70">
          Aberdyfi, Mid-Wales, United Kingdom<br />
          <a href={`mailto:${SITE.email}`} class="text-[var(--color-gold-300)] hover:underline">
            {SITE.email}
          </a>
        </address>
      </div>

      <!-- Explore -->
      <nav aria-label="Footer">
        <h2 class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-500)]">Explore</h2>
        <ul class="mt-4 space-y-2">
          {flatNav.map((item) => (
            <li>
              <a href={item.href} class="font-ui text-sm text-[var(--color-parchment)]/80 hover:text-[var(--color-gold-300)]">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Shop -->
      <div>
        <h2 class="font-ui text-xs uppercase tracking-[0.2em] text-[var(--color-gold-500)]">Online Shops</h2>
        <ul class="mt-4 space-y-2">
          <li>
            <a href={EXTERNAL.ebay} target="_blank" rel="noopener noreferrer" class="font-ui text-sm text-[var(--color-parchment)]/80 hover:text-[var(--color-gold-300)]">
              eBay Store
            </a>
          </li>
          <li>
            <a href={EXTERNAL.abebooks} target="_blank" rel="noopener noreferrer" class="font-ui text-sm text-[var(--color-parchment)]/80 hover:text-[var(--color-gold-300)]">
              AbeBooks Store
            </a>
          </li>
          <li>
            <a href={`mailto:${SITE.email}`} class="font-ui text-sm text-[var(--color-parchment)]/80 hover:text-[var(--color-gold-300)]">
              Buy direct (save fees)
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col gap-2 border-t border-[var(--color-parchment)]/10 py-6 font-ui text-xs text-[var(--color-parchment)]/55 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {SITE.name}. All rights reserved.</p>
      <p>Trading as Festival Art and Books since 2009 · {SITE.tagline}</p>
    </div>
  </Container>
</footer>
