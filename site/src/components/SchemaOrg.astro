---
/**
 * Renders one or more JSON-LD blocks. Pass any schema.org object(s) via `schema`.
 * Co-locate schema with the page — build the object in the page frontmatter and pass it here.
 *
 * Helpers below construct the recurring entities (Organization, Person, Breadcrumbs)
 * from src/lib/site.ts so they stay consistent sitewide. See research/seo-geo-research.md §5.
 */
interface Props {
  schema: Record<string, any> | Record<string, any>[];
}
const { schema }: Props = Astro.props;
const blocks = Array.isArray(schema) ? schema : [schema];
---
{blocks.map((block) => (
  <script type="application/ld+json" set:html={JSON.stringify(block)} is:inline />
))}
